{
    "version": "2.0.0",
    "options": {
        "env": {
            "BOOT_SIZE": "2048",
            "BUILD_DIR": "build",
            "BUILD_NAME": "application",
            "COMPILE_C_AS_CPP": "1",
            "COMPILER_DEBUG": "1",
            "COMPILER_OPT": "-Og",
            "COMPILER_PATH": "",
            "COMPILER_STD_C": "gnu17",
            "COMPILER_STD_CPP": "c++17",
            "EXCLUDE_DIRS": "_hide/ doc/ Release/ temp/",
            "LIBRARY_PATH": "",
            "MCU_DEVICE_NAME": "atmega328p",
            "PROGRAMMER_CONFIG_FILE": "/etc/avrdude.conf",
            "PROGRAMMER_TYPE": "arduino",
            "USER_DEFINES_ASM": "",
            "USER_DEFINES_C": "",
            "USER_DEFINES_CPP": "",
            "USER_FLAGS_ASM": "",
            "USER_FLAGS_C": "-Wno-switch -fno-threadsafe-statics -Wl,--gc-sections",
