 870:funsape/util/../globalDefines.hpp **** )
 871:funsape/util/../globalDefines.hpp **** 
 872:funsape/util/../globalDefines.hpp **** //!
 873:funsape/util/../globalDefines.hpp **** //! @def            truncateBetween(var, min, max)
 874:funsape/util/../globalDefines.hpp **** //! @details        Truncates (trims) the value between maximum and minimum
 875:funsape/util/../globalDefines.hpp **** //!                     values.
 876:funsape/util/../globalDefines.hpp **** //! @warning        The macro-function will not work correctly if @a min is
 877:funsape/util/../globalDefines.hpp **** //!                     greater than @a max.
 878:funsape/util/../globalDefines.hpp **** //! @param[in]      var                 value to be truncated
 879:funsape/util/../globalDefines.hpp **** //! @param[in]      max                 maximum allowed value
 880:funsape/util/../globalDefines.hpp **** //! @param[in]      min                 minimum allowed value
 881:funsape/util/../globalDefines.hpp **** //! @return         @a min              if the value is lower than @a min
 882:funsape/util/../globalDefines.hpp **** //! @return         @a max              if the value is greater than @a max
 883:funsape/util/../globalDefines.hpp **** //! @return         @a var              if the value is placed between @a min
 884:funsape/util/../globalDefines.hpp **** //!                                          and @a max
 885:funsape/util/../globalDefines.hpp **** //!
 886:funsape/util/../globalDefines.hpp **** #define truncateBetween(var, min, max)  (       \
 887:funsape/util/../globalDefines.hpp ****         ((var) < (min))                         \
 888:funsape/util/../globalDefines.hpp ****         ? (min)                                 \
 889:funsape/util/../globalDefines.hpp ****         : (((var) > (max))                      \
 890:funsape/util/../globalDefines.hpp ****                 ? (max)                         \
 891:funsape/util/../globalDefines.hpp ****                 : (var)                         \
 892:funsape/util/../globalDefines.hpp ****         )                                       \
 893:funsape/util/../globalDefines.hpp **** )
