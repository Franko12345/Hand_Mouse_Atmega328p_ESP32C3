1290:funsape/util/../globalDefines.hpp ****     //                 Z-AXIS     Y-AXIS     X-AXIS
1291:funsape/util/../globalDefines.hpp ****     NONE            = (0 << 2) | (0 << 1) | (0 << 0),   //!< No axis selected
1292:funsape/util/../globalDefines.hpp ****     X               = (0 << 2) | (0 << 1) | (1 << 0),   //!< X axis selected
