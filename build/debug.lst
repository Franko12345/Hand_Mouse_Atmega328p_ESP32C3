1305:funsape/util/../globalDefines.hpp **** // Implementation of bitwise operators for Axis enum class to allow mask
GAS LISTING /tmp/ccC7wAFe.s 			page 36


1306:funsape/util/../globalDefines.hpp **** //      combinations.
1307:funsape/util/../globalDefines.hpp **** 
1308:funsape/util/../globalDefines.hpp **** Axis inlined operator|(Axis a, Axis b)
1309:funsape/util/../globalDefines.hpp **** {
1310:funsape/util/../globalDefines.hpp ****     return static_cast<Axis>(static_cast<uint8_t>(a) | static_cast<uint8_t>(b));
1311:funsape/util/../globalDefines.hpp **** }
1312:funsape/util/../globalDefines.hpp **** 
1313:funsape/util/../globalDefines.hpp **** Axis inlined &operator|=(Axis &a, Axis b)
1314:funsape/util/../globalDefines.hpp **** {
1315:funsape/util/../globalDefines.hpp ****     return a = static_cast<Axis>(static_cast<uint8_t>(a) | static_cast<uint8_t>(b));
1316:funsape/util/../globalDefines.hpp **** }
1317:funsape/util/../globalDefines.hpp **** 
1318:funsape/util/../globalDefines.hpp **** Axis inlined operator&(Axis a, Axis b)
1319:funsape/util/../globalDefines.hpp **** {
1320:funsape/util/../globalDefines.hpp ****     return static_cast<Axis>(static_cast<uint8_t>(a) & static_cast<uint8_t>(b));
1321:funsape/util/../globalDefines.hpp **** }
1322:funsape/util/../globalDefines.hpp **** 
1323:funsape/util/../globalDefines.hpp **** Axis inlined &operator&=(Axis &a, Axis b)
1324:funsape/util/../globalDefines.hpp **** {
1325:funsape/util/../globalDefines.hpp ****     return a = static_cast<Axis>(static_cast<uint8_t>(a) & static_cast<uint8_t>(b));
1326:funsape/util/../globalDefines.hpp **** }
