 223:funsape/util/../globalDefines.hpp **** 
 224:funsape/util/../globalDefines.hpp **** #ifndef clrBit
 225:funsape/util/../globalDefines.hpp **** //!
 226:funsape/util/../globalDefines.hpp **** //! @def            clrBit(reg, pos)
 227:funsape/util/../globalDefines.hpp **** //! @details        Clears the bit at position @a pos of the register or
 228:funsape/util/../globalDefines.hpp **** //!                     variable @a reg.
 229:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 230:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be cleared
 231:funsape/util/../globalDefines.hpp **** //!
 232:funsape/util/../globalDefines.hpp **** #   define clrBit(reg, pos)             do{     \
 233:funsape/util/../globalDefines.hpp ****         (reg) &= ~(1 << (pos));                 \
 234:funsape/util/../globalDefines.hpp ****     }while(0)
 235:funsape/util/../globalDefines.hpp **** #endif
 236:funsape/util/../globalDefines.hpp **** 
 237:funsape/util/../globalDefines.hpp **** #ifndef cplBit
 238:funsape/util/../globalDefines.hpp **** //!
 239:funsape/util/../globalDefines.hpp **** //! @def            cplBit(reg, pos)
 240:funsape/util/../globalDefines.hpp **** //! @details        Complements (invert) the bit at position @a pos of the
 241:funsape/util/../globalDefines.hpp **** //!                     register or variable @a reg.
 242:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 243:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be complemented
 244:funsape/util/../globalDefines.hpp **** //!
 245:funsape/util/../globalDefines.hpp **** #   define cplBit(reg, pos)             do{     \
 246:funsape/util/../globalDefines.hpp ****         (reg) ^= (1 << (pos));                  \
 247:funsape/util/../globalDefines.hpp ****     }while(0)
 248:funsape/util/../globalDefines.hpp **** #endif
 249:funsape/util/../globalDefines.hpp **** 
 250:funsape/util/../globalDefines.hpp **** #ifndef setBit
 251:funsape/util/../globalDefines.hpp **** //!
 252:funsape/util/../globalDefines.hpp **** //! @def            setBit(reg, pos)
 253:funsape/util/../globalDefines.hpp **** //! @details        Sets the bit at position @a pos of the register or variable
 254:funsape/util/../globalDefines.hpp **** //!                     @a reg.
 255:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 256:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be set
 257:funsape/util/../globalDefines.hpp **** //!
 258:funsape/util/../globalDefines.hpp **** #   define setBit(reg, pos)             do{     \
 259:funsape/util/../globalDefines.hpp ****         (reg) |= (1 << (pos));                  \
 260:funsape/util/../globalDefines.hpp ****     }while(0)
 261:funsape/util/../globalDefines.hpp **** #endif
 262:funsape/util/../globalDefines.hpp **** 
 263:funsape/util/../globalDefines.hpp **** //     ///////////////////////     BIT TESTING    ///////////////////////     //
 264:funsape/util/../globalDefines.hpp **** 
 265:funsape/util/../globalDefines.hpp **** #ifndef isBitClr
 266:funsape/util/../globalDefines.hpp **** //!
 267:funsape/util/../globalDefines.hpp **** //! @def            isBitClr(reg, pos)
 268:funsape/util/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 269:funsape/util/../globalDefines.hpp **** //!                     variable @a reg is cleared.
 270:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 271:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 272:funsape/util/../globalDefines.hpp **** //! @retval         true                if the bit is cleared
 273:funsape/util/../globalDefines.hpp **** //! @retval         false               if the bit is set
 274:funsape/util/../globalDefines.hpp **** //!
 275:funsape/util/../globalDefines.hpp **** #   define isBitClr(reg, pos)           (bool_t)(!isBitSet(reg,pos))
 276:funsape/util/../globalDefines.hpp **** #endif
 277:funsape/util/../globalDefines.hpp **** 
 278:funsape/util/../globalDefines.hpp **** #ifndef isBitSet
 279:funsape/util/../globalDefines.hpp **** //!
GAS LISTING /tmp/ccC7wAFe.s 			page 18


 280:funsape/util/../globalDefines.hpp **** //! @def            isBitSet(reg, pos)
 281:funsape/util/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 282:funsape/util/../globalDefines.hpp **** //!                     variable @a reg is set.
 283:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 284:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 285:funsape/util/../globalDefines.hpp **** //! @retval         true                if the bit is set
 286:funsape/util/../globalDefines.hpp **** //! @retval         false               if the bit is cleared
 287:funsape/util/../globalDefines.hpp **** //!
 288:funsape/util/../globalDefines.hpp **** #   define isBitSet(reg, pos)           (bool_t)(((reg) >> (pos)) & 1)
 289:funsape/util/../globalDefines.hpp **** #endif
 290:funsape/util/../globalDefines.hpp **** 
