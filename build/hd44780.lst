 169:funsape/device/../globalDefines.hpp ****         (IS_GPIO_ALL_INSTANCE(gpioPort))                \
 170:funsape/device/../globalDefines.hpp ****         ? true                                          \
 171:funsape/device/../globalDefines.hpp ****         : false                                         \
 172:funsape/device/../globalDefines.hpp **** )
