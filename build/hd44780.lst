 342:funsape/device/../globalDefines.hpp **** #ifndef clrMask
 343:funsape/device/../globalDefines.hpp **** //!
 344:funsape/device/../globalDefines.hpp **** //! @def            clrMask(reg, mask)
 345:funsape/device/../globalDefines.hpp **** //! @details        Clears the bits of the register or variable @a reg that are
 346:funsape/device/../globalDefines.hpp **** //!                     set on the supplied mask @a mask.
 347:funsape/device/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 348:funsape/device/../globalDefines.hpp **** //! @param[in]      mask                one-mask of the bits to be cleared
 349:funsape/device/../globalDefines.hpp **** //!
 350:funsape/device/../globalDefines.hpp **** #   define clrMask(reg, mask)           do{     \
 351:funsape/device/../globalDefines.hpp ****         (reg) &= ~(mask);                       \
 352:funsape/device/../globalDefines.hpp ****     }while(0)
