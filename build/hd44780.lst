 222:funsape/device/../globalDefines.hpp **** //     //////////////////////     BIT HANDLING     //////////////////////     //
 223:funsape/device/../globalDefines.hpp **** 
 224:funsape/device/../globalDefines.hpp **** #ifndef clrBit
 225:funsape/device/../globalDefines.hpp **** //!
 226:funsape/device/../globalDefines.hpp **** //! @def            clrBit(reg, pos)
 227:funsape/device/../globalDefines.hpp **** //! @details        Clears the bit at position @a pos of the register or
 228:funsape/device/../globalDefines.hpp **** //!                     variable @a reg.
 229:funsape/device/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 230:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be cleared
 231:funsape/device/../globalDefines.hpp **** //!
 232:funsape/device/../globalDefines.hpp **** #   define clrBit(reg, pos)             do{     \
 233:funsape/device/../globalDefines.hpp ****         (reg) &= ~(1 << (pos));                 \
 234:funsape/device/../globalDefines.hpp ****     }while(0)
 235:funsape/device/../globalDefines.hpp **** #endif
 236:funsape/device/../globalDefines.hpp **** 
 237:funsape/device/../globalDefines.hpp **** #ifndef cplBit
 238:funsape/device/../globalDefines.hpp **** //!
 239:funsape/device/../globalDefines.hpp **** //! @def            cplBit(reg, pos)
 240:funsape/device/../globalDefines.hpp **** //! @details        Complements (invert) the bit at position @a pos of the
 241:funsape/device/../globalDefines.hpp **** //!                     register or variable @a reg.
 242:funsape/device/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 243:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be complemented
 244:funsape/device/../globalDefines.hpp **** //!
 245:funsape/device/../globalDefines.hpp **** #   define cplBit(reg, pos)             do{     \
 246:funsape/device/../globalDefines.hpp ****         (reg) ^= (1 << (pos));                  \
 247:funsape/device/../globalDefines.hpp ****     }while(0)
 248:funsape/device/../globalDefines.hpp **** #endif
 249:funsape/device/../globalDefines.hpp **** 
 250:funsape/device/../globalDefines.hpp **** #ifndef setBit
 251:funsape/device/../globalDefines.hpp **** //!
 252:funsape/device/../globalDefines.hpp **** //! @def            setBit(reg, pos)
 253:funsape/device/../globalDefines.hpp **** //! @details        Sets the bit at position @a pos of the register or variable
 254:funsape/device/../globalDefines.hpp **** //!                     @a reg.
 255:funsape/device/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 256:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be set
 257:funsape/device/../globalDefines.hpp **** //!
 258:funsape/device/../globalDefines.hpp **** #   define setBit(reg, pos)             do{     \
 259:funsape/device/../globalDefines.hpp ****         (reg) |= (1 << (pos));                  \
 260:funsape/device/../globalDefines.hpp ****     }while(0)
 261:funsape/device/../globalDefines.hpp **** #endif
 262:funsape/device/../globalDefines.hpp **** 
 263:funsape/device/../globalDefines.hpp **** //     ///////////////////////     BIT TESTING    ///////////////////////     //
 264:funsape/device/../globalDefines.hpp **** 
 265:funsape/device/../globalDefines.hpp **** #ifndef isBitClr
 266:funsape/device/../globalDefines.hpp **** //!
 267:funsape/device/../globalDefines.hpp **** //! @def            isBitClr(reg, pos)
 268:funsape/device/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 269:funsape/device/../globalDefines.hpp **** //!                     variable @a reg is cleared.
 270:funsape/device/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 271:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 272:funsape/device/../globalDefines.hpp **** //! @retval         true                if the bit is cleared
 273:funsape/device/../globalDefines.hpp **** //! @retval         false               if the bit is set
 274:funsape/device/../globalDefines.hpp **** //!
 275:funsape/device/../globalDefines.hpp **** #   define isBitClr(reg, pos)           (bool_t)(!isBitSet(reg,pos))
 276:funsape/device/../globalDefines.hpp **** #endif
 277:funsape/device/../globalDefines.hpp **** 
 278:funsape/device/../globalDefines.hpp **** #ifndef isBitSet
GAS LISTING /tmp/ccQ2E2aO.s 			page 53


 279:funsape/device/../globalDefines.hpp **** //!
 280:funsape/device/../globalDefines.hpp **** //! @def            isBitSet(reg, pos)
 281:funsape/device/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 282:funsape/device/../globalDefines.hpp **** //!                     variable @a reg is set.
 283:funsape/device/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 284:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 285:funsape/device/../globalDefines.hpp **** //! @retval         true                if the bit is set
 286:funsape/device/../globalDefines.hpp **** //! @retval         false               if the bit is cleared
 287:funsape/device/../globalDefines.hpp **** //!
 288:funsape/device/../globalDefines.hpp **** #   define isBitSet(reg, pos)           (bool_t)(((reg) >> (pos)) & 1)
 289:funsape/device/../globalDefines.hpp **** #endif
 290:funsape/device/../globalDefines.hpp **** 
 291:funsape/device/../globalDefines.hpp **** //     ///////////////////////     BIT LOOPING    ///////////////////////     //
 292:funsape/device/../globalDefines.hpp **** 
 293:funsape/device/../globalDefines.hpp **** #ifndef waitUntilBitIsClear
 294:funsape/device/../globalDefines.hpp **** //!
 295:funsape/device/../globalDefines.hpp **** //! @def            waitUntilBitIsClear(reg, pos)
 296:funsape/device/../globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 297:funsape/device/../globalDefines.hpp **** //!                     in register or variable @a reg is set.
 298:funsape/device/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 299:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 300:funsape/device/../globalDefines.hpp **** //!
 301:funsape/device/../globalDefines.hpp **** #   define waitUntilBitIsClear(reg, pos)        do{     \
 302:funsape/device/../globalDefines.hpp ****         doNothing();                                    \
 303:funsape/device/../globalDefines.hpp ****     }while(isBitSet((reg), (pos)))
 304:funsape/device/../globalDefines.hpp **** #endif
 305:funsape/device/../globalDefines.hpp **** 
 306:funsape/device/../globalDefines.hpp **** #ifndef waitUntilBitIsSet
 307:funsape/device/../globalDefines.hpp **** //!
 308:funsape/device/../globalDefines.hpp **** //! @def            waitUntilBitIsSet(reg, pos)
 309:funsape/device/../globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 310:funsape/device/../globalDefines.hpp **** //!                     in register or variable @a reg is cleared.
 311:funsape/device/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 312:funsape/device/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 313:funsape/device/../globalDefines.hpp **** //!
 314:funsape/device/../globalDefines.hpp **** #   define waitUntilBitIsSet(reg, pos)  do{     \
 315:funsape/device/../globalDefines.hpp ****         doNothing();                            \
 316:funsape/device/../globalDefines.hpp ****     } while (isBitClr((reg), (pos)))
 317:funsape/device/../globalDefines.hpp **** #endif
 318:funsape/device/../globalDefines.hpp **** 
 319:funsape/device/../globalDefines.hpp **** // +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 320:funsape/device/../globalDefines.hpp **** // Doxygen: End subgroup "Bit_Handling" in "Global_Definitions"
 321:funsape/device/../globalDefines.hpp **** // +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 322:funsape/device/../globalDefines.hpp **** 
 323:funsape/device/../globalDefines.hpp **** //!
 324:funsape/device/../globalDefines.hpp **** //! @}
 325:funsape/device/../globalDefines.hpp **** //!
