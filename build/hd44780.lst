 354:funsape/device/../globalDefines.hpp **** 
 355:funsape/device/../globalDefines.hpp **** #ifndef cplMask
 356:funsape/device/../globalDefines.hpp **** //!
 357:funsape/device/../globalDefines.hpp **** //! @def            cplMask(reg, mask)
 358:funsape/device/../globalDefines.hpp **** //! @details        Complements (inverts) the bits of the register or variable
 359:funsape/device/../globalDefines.hpp **** //!                     @a reg that are set on the supplied mask @a mask.
 360:funsape/device/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 361:funsape/device/../globalDefines.hpp **** //! @param[in]      mask                one-mask of the bits to be complemented
 362:funsape/device/../globalDefines.hpp **** //!
 363:funsape/device/../globalDefines.hpp **** #   define cplMask(reg, mask)           do{     \
 364:funsape/device/../globalDefines.hpp ****         (reg) ^= (mask);                        \
 365:funsape/device/../globalDefines.hpp ****     }while(0)
 366:funsape/device/../globalDefines.hpp **** #endif
