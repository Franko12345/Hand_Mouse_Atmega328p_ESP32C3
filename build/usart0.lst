 144:funsape/peripheral/usart0.hpp ****     //!
 145:funsape/peripheral/usart0.hpp ****     //! \brief      USART0 Operation Mode enumeration.
 146:funsape/peripheral/usart0.hpp ****     //! \details    Operation mode associated with the USART0.
 147:funsape/peripheral/usart0.hpp ****     //! \warning    The value associate with the symbolic names may change
 148:funsape/peripheral/usart0.hpp ****     //!                 between builds and might not reflect the register/bits
 149:funsape/peripheral/usart0.hpp ****     //!                 real values. In order to ensure compatibility between
 150:funsape/peripheral/usart0.hpp ****     //!                 builds, always refer to the SYMBOLIC NAME, instead of
 151:funsape/peripheral/usart0.hpp ****     //!                 the VALUE.
 152:funsape/peripheral/usart0.hpp ****     //!
 153:funsape/peripheral/usart0.hpp ****     enum class Mode : uint8_t {
 154:funsape/peripheral/usart0.hpp ****         ASYNCHRONOUS                            = 0,    //!< Peripheral in UART without double spee
 155:funsape/peripheral/usart0.hpp ****         ASYNCHRONOUS_DOUBLE_SPEED               = 1,    //!< Peripheral in UART with double speed m
 156:funsape/peripheral/usart0.hpp ****         SYNCHRONOUS_TX_RISING_RX_FALLING        = 2,    //!< Peripheral in USART mode on falling ed
 157:funsape/peripheral/usart0.hpp ****         SYNCHRONOUS_TX_FALLING_RX_RISING        = 3,    //!< Peripheral in USART mode on rising edg
 158:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_0                       = 4,    //!< Peripheral in master SPI mode 0.
 159:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_1                       = 5,    //!< Peripheral in master SPI mode 1.
 160:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_2                       = 6,    //!< Peripheral in master SPI mode 2.
 161:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_3                       = 7,    //!< Peripheral in master SPI mode 3.
 162:funsape/peripheral/usart0.hpp ****     };
