 107:funsape/peripheral/../util/systemStatus.hpp ****     enum class ClockPrescaler {
 108:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_1                     = 0,    //!< Prescaler off. System clock is not divided.
 109:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_2                     = 1,    //!< I/O clock frequency will be System Clock divid
 110:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_4                     = 2,    //!< I/O clock frequency will be System Clock divid
 111:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_8                     = 3,    //!< I/O clock frequency will be System Clock divid
 112:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_32                    = 4,    //!< I/O clock frequency will be System Clock divid
 113:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_64                    = 5,    //!< I/O clock frequency will be System Clock divid
 114:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_128                   = 6,    //!< I/O clock frequency will be System Clock divid
 115:funsape/peripheral/../util/systemStatus.hpp ****         PRESCALER_256                   = 7,    //!< I/O clock frequency will be System Clock divid
 116:funsape/peripheral/../util/systemStatus.hpp ****     };
