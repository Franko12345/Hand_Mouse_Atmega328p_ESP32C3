 415:funsape/peripheral/twi.cpp **** 
 416:funsape/peripheral/twi.cpp **** void Twi::interruptHandler(void)
 417:funsape/peripheral/twi.cpp **** {
 418:funsape/peripheral/twi.cpp ****     static uint8_t twiBufferPointer;
 419:funsape/peripheral/twi.cpp **** 
 420:funsape/peripheral/twi.cpp ****     State twiState = (Twi::State)(TWSR & 0xFC);
 421:funsape/peripheral/twi.cpp **** 
 422:funsape/peripheral/twi.cpp ****     switch(twiState) {
 423:funsape/peripheral/twi.cpp ****     case Twi::State::START:             // START has been transmitted
 424:funsape/peripheral/twi.cpp ****     case Twi::State::REP_START:         // Repeated START has been transmitted
 425:funsape/peripheral/twi.cpp ****         twiBufferPointer = 0;           // Set buffer pointer to the TWI Address location
 426:funsape/peripheral/twi.cpp ****     case Twi::State::MTX_ADR_ACK:       // SLA+W has been transmitted and ACK received
 427:funsape/peripheral/twi.cpp ****     case Twi::State::MTX_DATA_ACK:      // Data byte has been transmitted and ACK received
 428:funsape/peripheral/twi.cpp ****         if(twiBufferPointer < this->_bufferLength) {
 429:funsape/peripheral/twi.cpp ****             TWDR = this->_bufferData[twiBufferPointer++];
 430:funsape/peripheral/twi.cpp ****             TWCR = (1 << TWEN) | (1 << TWIE) | (1 << TWINT);
 431:funsape/peripheral/twi.cpp ****         } else {                        // Send STOP after last byte
 432:funsape/peripheral/twi.cpp ****             this->_lastTransOk = true;  // Set status bits to completed successfully
 433:funsape/peripheral/twi.cpp ****             TWCR = (1 << TWEN) | (1 << TWINT) | (1 << TWSTO);
 434:funsape/peripheral/twi.cpp ****         }
 435:funsape/peripheral/twi.cpp ****         break;
 436:funsape/peripheral/twi.cpp ****     case Twi::State::MRX_DATA_ACK:      // Data byte has been received and ACK transmitted
 437:funsape/peripheral/twi.cpp ****         this->_bufferData[twiBufferPointer++] = TWDR;
 438:funsape/peripheral/twi.cpp ****     case Twi::State::MRX_ADR_ACK:       // SLA+R has been transmitted and ACK received
 439:funsape/peripheral/twi.cpp ****         if(twiBufferPointer < (this->_bufferLength - 1)) {  // Detect the last byte to NACK it
 440:funsape/peripheral/twi.cpp ****             TWCR = (1 << TWEN) | (1 << TWIE) | (1 << TWINT) | (1 << TWEA);
 441:funsape/peripheral/twi.cpp ****         } else {                        // Send NACK after next reception
 442:funsape/peripheral/twi.cpp ****             TWCR = (1 << TWEN) | (1 << TWIE) | (1 << TWINT);
 443:funsape/peripheral/twi.cpp ****         }
 444:funsape/peripheral/twi.cpp ****         break;
 445:funsape/peripheral/twi.cpp ****     case Twi::State::MRX_DATA_NACK:     // Data byte has been received and NACK transmitted
 446:funsape/peripheral/twi.cpp ****         this->_bufferData[twiBufferPointer] = TWDR;
 447:funsape/peripheral/twi.cpp ****         this->_lastTransOk = true;      // Set status bits to completed successfully
 448:funsape/peripheral/twi.cpp ****         TWCR = (1 << TWEN) | (1 << TWINT) | (1 << TWSTO);
 449:funsape/peripheral/twi.cpp ****         break;
 450:funsape/peripheral/twi.cpp ****     case Twi::State::ARB_LOST:          // Arbitration lost
 451:funsape/peripheral/twi.cpp ****         TWCR = (1 << TWEN) | (1 << TWIE) | (1 << TWINT) | (1 << TWSTA);
 452:funsape/peripheral/twi.cpp ****         break;
 453:funsape/peripheral/twi.cpp ****     case Twi::State::MTX_ADR_NACK:      // SLA+W has been transmitted and NACK received
 454:funsape/peripheral/twi.cpp ****     case Twi::State::MRX_ADR_NACK:      // SLA+R has been transmitted and NACK received
 455:funsape/peripheral/twi.cpp ****     case Twi::State::MTX_DATA_NACK:     // Data byte has been transmitted and NACK received
 456:funsape/peripheral/twi.cpp ****     case Twi::State::BUS_ERROR:         // Bus error due to an illegal START or STOP condition
GAS LISTING /tmp/ccQ8U2zo.s 			page 23


 457:funsape/peripheral/twi.cpp ****     default:
 458:funsape/peripheral/twi.cpp ****         this->_twiError = TWSR;         // Store TWSR and automatically sets clears noErrors bit
 459:funsape/peripheral/twi.cpp ****         TWCR = (1 << TWEN);             // Reset TWI Interface
 460:funsape/peripheral/twi.cpp ****         break;
 461:funsape/peripheral/twi.cpp ****     }
 462:funsape/peripheral/twi.cpp **** }
 463:funsape/peripheral/twi.cpp **** 
