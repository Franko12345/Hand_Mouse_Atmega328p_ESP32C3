 251:funsape/peripheral/twi.cpp ****     // Check for errors - Clock speed
 252:funsape/peripheral/twi.cpp ****     if(clockSpeed_p < constTwiBitRateMin) {
 253:funsape/peripheral/twi.cpp ****         // Returns error
 254:funsape/peripheral/twi.cpp ****         this->_lastError = Error::CLOCK_SPEED_TOO_LOW;
 255:funsape/peripheral/twi.cpp ****         return false;
 256:funsape/peripheral/twi.cpp ****     } else if(clockSpeed_p > constTwiBitRateMax) {
 257:funsape/peripheral/twi.cpp ****         // Returns error
 258:funsape/peripheral/twi.cpp ****         this->_lastError = Error::CLOCK_SPEED_TOO_HIGH;
 259:funsape/peripheral/twi.cpp ****         return false;
 260:funsape/peripheral/twi.cpp ****     }
 261:funsape/peripheral/twi.cpp ****     // Check for errors - Buffer size
