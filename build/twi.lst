 337:funsape/peripheral/twi.cpp **** bool_t Twi::_waitWhileIsBusy(void)
 338:funsape/peripheral/twi.cpp **** {
 339:funsape/peripheral/twi.cpp ****     // Local variables
 340:funsape/peripheral/twi.cpp ****     uint32_t stopwatchMark;
 341:funsape/peripheral/twi.cpp ****     uint32_t stopwatchDeadline;
 342:funsape/peripheral/twi.cpp **** 
GAS LISTING /tmp/ccQ8U2zo.s 			page 21


 343:funsape/peripheral/twi.cpp ****     // Evaluates stopwatch deadline
 344:funsape/peripheral/twi.cpp ****     if(this->_timeout == 0) {
 345:funsape/peripheral/twi.cpp ****         stopwatchDeadline = 0xFFFFFFFF;
 346:funsape/peripheral/twi.cpp ****     } else {
 347:funsape/peripheral/twi.cpp ****         stopwatchDeadline = 0;
 348:funsape/peripheral/twi.cpp ****         systemStatus.getStopwatchValue(&stopwatchDeadline);
 349:funsape/peripheral/twi.cpp ****         stopwatchDeadline += this->_timeout;
 350:funsape/peripheral/twi.cpp ****     }
 351:funsape/peripheral/twi.cpp **** 
 352:funsape/peripheral/twi.cpp ****     // Wait until TWI is ready for next transmission
 353:funsape/peripheral/twi.cpp ****     do {
 354:funsape/peripheral/twi.cpp ****         stopwatchMark = 0;
 355:funsape/peripheral/twi.cpp ****         systemStatus.getStopwatchValue(&stopwatchMark);
 356:funsape/peripheral/twi.cpp ****         if(stopwatchMark > stopwatchDeadline) {
 357:funsape/peripheral/twi.cpp ****             // Returns error
 358:funsape/peripheral/twi.cpp ****             this->_lastError = Error::TIMED_OUT;
 359:funsape/peripheral/twi.cpp ****             return false;
 360:funsape/peripheral/twi.cpp ****         }
 361:funsape/peripheral/twi.cpp ****     } while(isBitSet(TWCR, TWIE));
 362:funsape/peripheral/twi.cpp **** 
 363:funsape/peripheral/twi.cpp ****     // Returns successfully
 364:funsape/peripheral/twi.cpp ****     this->_lastError = Error::NONE;
 365:funsape/peripheral/twi.cpp ****     return true;
 366:funsape/peripheral/twi.cpp **** }
 367:funsape/peripheral/twi.cpp **** 
 368:funsape/peripheral/twi.cpp **** bool_t Twi::_startTransmission(void)
 369:funsape/peripheral/twi.cpp **** {
 370:funsape/peripheral/twi.cpp ****     this->_lastTransOk = false;
 371:funsape/peripheral/twi.cpp ****     this->_state = State::NO_STATE;
 372:funsape/peripheral/twi.cpp ****     TWCR = 0 |
 373:funsape/peripheral/twi.cpp ****             (1 << TWEN) |
 374:funsape/peripheral/twi.cpp ****             (1 << TWIE) |
 375:funsape/peripheral/twi.cpp ****             (1 << TWINT) |
 376:funsape/peripheral/twi.cpp ****             (1 << TWSTA);
 377:funsape/peripheral/twi.cpp **** 
 378:funsape/peripheral/twi.cpp ****     // Returns successfully
 379:funsape/peripheral/twi.cpp ****     this->_lastError = Error::NONE;
 380:funsape/peripheral/twi.cpp ****     return true;
 381:funsape/peripheral/twi.cpp **** }
