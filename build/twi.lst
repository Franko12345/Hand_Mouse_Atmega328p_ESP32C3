 390:funsape/peripheral/twi.cpp ****     }
 391:funsape/peripheral/twi.cpp ****     for(uint8_t i = 0; i < msgSize_p; i++) {
 392:funsape/peripheral/twi.cpp ****         msg_p[i] = this->_bufferData[i + 1];
 393:funsape/peripheral/twi.cpp ****     }
 394:funsape/peripheral/twi.cpp **** 
 395:funsape/peripheral/twi.cpp ****     // Returns successfully
 396:funsape/peripheral/twi.cpp ****     this->_lastError = Error::NONE;
 397:funsape/peripheral/twi.cpp ****     return true;
 398:funsape/peripheral/twi.cpp **** }
