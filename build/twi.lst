 280:funsape/peripheral/twi.cpp ****         this->_lastError = Error::MEMORY_ALLOCATION;
 281:funsape/peripheral/twi.cpp ****         return false;
 282:funsape/peripheral/twi.cpp ****     }
 283:funsape/peripheral/twi.cpp ****     this->_bufferMaxSize = bufferSize_p + 2;
 284:funsape/peripheral/twi.cpp ****     this->_bufferIndex = 0;
 285:funsape/peripheral/twi.cpp ****     this->_bufferLength = 0;
 286:funsape/peripheral/twi.cpp **** 
 287:funsape/peripheral/twi.cpp ****     // Evaluate BIT RATE and PRESCALER
 288:funsape/peripheral/twi.cpp ****     systemStatus.getCpuClock(&aux32);
 289:funsape/peripheral/twi.cpp ****     aux32 /= clockSpeed_p;
 290:funsape/peripheral/twi.cpp ****     // aux16 = (uint16_t)aux32;
 291:funsape/peripheral/twi.cpp ****     aux32 -= 16;
 292:funsape/peripheral/twi.cpp ****     aux32 /= 2;
 293:funsape/peripheral/twi.cpp ****     if(aux32 <= 255) {                  // Prescaler 1
 294:funsape/peripheral/twi.cpp ****         aux8 = (uint8_t)aux32;
 295:funsape/peripheral/twi.cpp ****     } else if(aux32 <= 1020) {          // Prescaler 4
 296:funsape/peripheral/twi.cpp ****         aux8 = (uint8_t)(aux32 / 4);
 297:funsape/peripheral/twi.cpp ****         TWSR |= (1 << TWPS0);
 298:funsape/peripheral/twi.cpp ****     } else if(aux32 <= 4080) {          // Prescaler 16
 299:funsape/peripheral/twi.cpp ****         aux8 = (uint8_t)(aux32 / 16);
 300:funsape/peripheral/twi.cpp ****         TWSR |= (2 << TWPS0);
 301:funsape/peripheral/twi.cpp ****     } else if(aux32 <= 16320) {         // Prescaler 64
 302:funsape/peripheral/twi.cpp ****         aux8 = (uint8_t)(aux32 / 64);
 303:funsape/peripheral/twi.cpp ****         TWSR |= (3 << TWPS0);
 304:funsape/peripheral/twi.cpp ****     }
 305:funsape/peripheral/twi.cpp **** 
 306:funsape/peripheral/twi.cpp ****     // Update TWI registers
 307:funsape/peripheral/twi.cpp ****     TWBR                                = aux8;
 308:funsape/peripheral/twi.cpp ****     TWDR                                = 0xFF;         // Release SDA
 309:funsape/peripheral/twi.cpp ****     setBit(TWCR, TWEN);                 // Activate TWI interface
 310:funsape/peripheral/twi.cpp ****     this->_initialized                  = true;
 311:funsape/peripheral/twi.cpp **** 
 312:funsape/peripheral/twi.cpp ****     // Returns successfully
 313:funsape/peripheral/twi.cpp ****     this->_lastError = Error::NONE;
 314:funsape/peripheral/twi.cpp ****     return true;
 315:funsape/peripheral/twi.cpp **** }
