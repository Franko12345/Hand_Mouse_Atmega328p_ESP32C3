 263:funsape/peripheral/twi.cpp ****         // Returns error
 264:funsape/peripheral/twi.cpp ****         this->_lastError = Error::BUFFER_SIZE_TOO_SMALL;
 265:funsape/peripheral/twi.cpp ****         return false;
 266:funsape/peripheral/twi.cpp ****     } else if(bufferSize_p > constTwiBufferSizeMax) {
 267:funsape/peripheral/twi.cpp ****         // Returns error
 268:funsape/peripheral/twi.cpp ****         this->_lastError = Error::BUFFER_SIZE_TOO_LARGE;
 269:funsape/peripheral/twi.cpp ****         return false;
 270:funsape/peripheral/twi.cpp ****     }
 271:funsape/peripheral/twi.cpp **** 
 272:funsape/peripheral/twi.cpp ****     // Allocates memory (Free first if already allocated)
 273:funsape/peripheral/twi.cpp ****     if(isPointerValid(this->_bufferData)) {
 274:funsape/peripheral/twi.cpp ****         free(this->_bufferData);
 275:funsape/peripheral/twi.cpp ****         this->_bufferData = nullptr;
 276:funsape/peripheral/twi.cpp ****     }
