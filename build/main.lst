 402:main.cpp      ****         overflows++;
 403:main.cpp      ****         ticks = timer1.getCounterValue(); // Re-read to guarantee accurate timing
 404:main.cpp      ****     }
 405:main.cpp      ****     sei();
 406:main.cpp      **** 
 407:main.cpp      ****     // Each overflow is 65536 ticks. Each tick is 0.5 microseconds.
 408:main.cpp      ****     // Total microseconds = (overflows * 65536 * 0.5) + (ticks * 0.5)
 409:main.cpp      ****     return (overflows * 32768) + (ticks >> 1);
 410:main.cpp      **** }
