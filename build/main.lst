 161:funsape/peripheral/pcint1.hpp ****     //! @enum       Pin
 162:funsape/peripheral/pcint1.hpp ****     //! @brief      Trigger Mode Pins enumeration.
 163:funsape/peripheral/pcint1.hpp ****     //! @details    Trigger Mode Pins associated with PCINT1.
 164:funsape/peripheral/pcint1.hpp ****     //! @warning    The value associate with the symbolic names may change
 165:funsape/peripheral/pcint1.hpp ****     //!                 between builds and might not reflect the register/bits
 166:funsape/peripheral/pcint1.hpp ****     //!                 real values. In order to ensure compatibility between
 167:funsape/peripheral/pcint1.hpp ****     //!                 builds, always refer to the SYMBOLIC NAME, instead of
 168:funsape/peripheral/pcint1.hpp ****     //!                 its VALUE.
 169:funsape/peripheral/pcint1.hpp ****     //!
 170:funsape/peripheral/pcint1.hpp ****     enum class Pin : uint8_t {
 171:funsape/peripheral/pcint1.hpp **** #if defined(MCU_PCINT1_PIN_8_EXISTS)
 172:funsape/peripheral/pcint1.hpp ****         PIN_PCINT8          = (1 << 0), //!< Enables trigger by PCINT8 pin.
 173:funsape/peripheral/pcint1.hpp **** #endif
 174:funsape/peripheral/pcint1.hpp **** #if defined(MCU_PCINT1_PIN_9_EXISTS)
 175:funsape/peripheral/pcint1.hpp ****         PIN_PCINT9          = (1 << 1), //!< Enables trigger by PCINT9 pin.
 176:funsape/peripheral/pcint1.hpp **** #endif
 177:funsape/peripheral/pcint1.hpp **** #if defined(MCU_PCINT1_PIN_10_EXISTS)
 178:funsape/peripheral/pcint1.hpp ****         PIN_PCINT10         = (1 << 2), //!< Enables trigger by PCINT10 pin.
