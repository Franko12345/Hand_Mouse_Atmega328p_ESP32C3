 440:main.cpp      **** uint32_t micros() {
 441:main.cpp      ****     uint32_t overflows;
 442:main.cpp      ****     uint16_t ticks;
 443:main.cpp      **** 
GAS LISTING /tmp/ccgHH0SV.s 			page 9


 444:main.cpp      ****     // Disable interrupts briefly to ensure atomic read of 16-bit register and 32-bit counter
 445:main.cpp      ****     cli();
 446:main.cpp      ****     overflows = timer1_overflows;
 447:main.cpp      ****     ticks = timer1.getCounterValue();;
 448:main.cpp      ****     
 449:main.cpp      ****     // Check if an overflow just occurred but hasn't been handled yet
 450:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 451:main.cpp      ****         overflows++;
 452:main.cpp      ****         ticks = timer1.getCounterValue(); // Re-read to guarantee accurate timing
 453:main.cpp      ****     }
 454:main.cpp      ****     sei();
 455:main.cpp      **** 
 456:main.cpp      ****     // Each overflow is 65536 ticks. Each tick is 0.5 microseconds.
 457:main.cpp      ****     // Total microseconds = (overflows * 65536 * 0.5) + (ticks * 0.5)
 458:main.cpp      ****     return (overflows * 32768) + (ticks >> 1);
 459:main.cpp      **** }
 460:main.cpp      **** 
 461:main.cpp      **** uint32_t get_millis() {
 462:main.cpp      ****     uint32_t overflows;
 463:main.cpp      ****     uint16_t ticks;
 464:main.cpp      **** 
 465:main.cpp      ****     cli();
 466:main.cpp      ****     overflows = timer1_overflows;
 467:main.cpp      ****     ticks = timer1.getCounterValue();
 468:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 469:main.cpp      ****         overflows++;
 470:main.cpp      ****         ticks = timer1.getCounterValue();
 471:main.cpp      ****     }
 472:main.cpp      ****     sei();
 473:main.cpp      **** 
 474:main.cpp      ****     // Em vez de calcular microssegundos, calculamos direto o milissegundo aproximado.
 475:main.cpp      ****     // 32768 / 1024 = 32 (Exato!) -> overflows * 32
 476:main.cpp      ****     // ticks / 2048 -> equivale a ticks >> 11
 477:main.cpp      ****     return (overflows * 32) + (ticks >> 11);
 478:main.cpp      **** }
