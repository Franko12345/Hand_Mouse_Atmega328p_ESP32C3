 353:main.cpp      **** //! Projeta um angulo (em milesimos de grau) numa coordenada de tela 0..32767,
 354:main.cpp      **** //! por TANGENTE (projecao "tela plana"). 'center' cai no meio (16384); em
 355:main.cpp      **** //! (center +- halfRange) chega nas bordas (0 e 32767). 'sens' e' ganho Q8
 356:main.cpp      **** //! (256 = 1.0x; 512 = 2.0x; 128 = 0.5x). Resultado sempre limitado a [0,32767].
 357:main.cpp      **** uint16_t projectTan(int32_t angle_mdeg, int32_t center_mdeg,
 358:main.cpp      ****                     int32_t halfRange_mdeg, uint16_t sens_q8)
 359:main.cpp      **** {
 360:main.cpp      **** 
 361:main.cpp      ****     int32_t rel = angle_mdeg - center_mdeg;
 362:main.cpp      ****     rel = truncateBetween(rel, -60000L, 60000L);              // evita div0/estouro do tan
 363:main.cpp      ****     int32_t tanRel  = ((int32_t)sini(rel) << 12) / cosi(rel);          // tan em Q12
 364:main.cpp      ****     int32_t tanHalf = ((int32_t)sini(halfRange_mdeg) << 12) / cosi(halfRange_mdeg);
 365:main.cpp      ****     int32_t offset  = ((int32_t)tanRel * sens_q8 * 1536) / tanHalf;      // 16384 na borda (sens=25
 366:main.cpp      ****     int32_t coord   = 16384L + offset;
 367:main.cpp      ****     return (uint16_t)truncateBetween(coord, 0L, 32767L);
 368:main.cpp      **** }
