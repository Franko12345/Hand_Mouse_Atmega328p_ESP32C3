 129:funsape/peripheral/usart0.hpp **** //!
 130:funsape/peripheral/usart0.hpp **** //! \brief          Usart0 class.
 131:funsape/peripheral/usart0.hpp **** //! \details        This class manages the Universal Synchronous/Asynchronous
 132:funsape/peripheral/usart0.hpp **** //!                     Receiver/Transmitter 0 (USART0) peripheral.
 133:funsape/peripheral/usart0.hpp **** //! \warning        An instance of this class is already defined as a global
 134:funsape/peripheral/usart0.hpp **** //!                     object. Therefore, there is not necessary, neither
 135:funsape/peripheral/usart0.hpp **** //!                     recommended to create another object of this class.
 136:funsape/peripheral/usart0.hpp **** //!
 137:funsape/peripheral/usart0.hpp **** class Usart0
 138:funsape/peripheral/usart0.hpp **** {
 139:funsape/peripheral/usart0.hpp ****     // -------------------------------------------------------------------------
 140:funsape/peripheral/usart0.hpp ****     // New data types ----------------------------------------------------------
 141:funsape/peripheral/usart0.hpp **** public:
 142:funsape/peripheral/usart0.hpp **** 
 143:funsape/peripheral/usart0.hpp ****     //     ///////////////     USART0 Operation Mode     ////////////////     //
 144:funsape/peripheral/usart0.hpp ****     //!
 145:funsape/peripheral/usart0.hpp ****     //! \brief      USART0 Operation Mode enumeration.
 146:funsape/peripheral/usart0.hpp ****     //! \details    Operation mode associated with the USART0.
 147:funsape/peripheral/usart0.hpp ****     //! \warning    The value associate with the symbolic names may change
 148:funsape/peripheral/usart0.hpp ****     //!                 between builds and might not reflect the register/bits
 149:funsape/peripheral/usart0.hpp ****     //!                 real values. In order to ensure compatibility between
 150:funsape/peripheral/usart0.hpp ****     //!                 builds, always refer to the SYMBOLIC NAME, instead of
 151:funsape/peripheral/usart0.hpp ****     //!                 the VALUE.
 152:funsape/peripheral/usart0.hpp ****     //!
 153:funsape/peripheral/usart0.hpp ****     enum class Mode : uint8_t {
 154:funsape/peripheral/usart0.hpp ****         ASYNCHRONOUS                            = 0,    //!< Peripheral in UART without double spee
 155:funsape/peripheral/usart0.hpp ****         ASYNCHRONOUS_DOUBLE_SPEED               = 1,    //!< Peripheral in UART with double speed m
 156:funsape/peripheral/usart0.hpp ****         SYNCHRONOUS_TX_RISING_RX_FALLING        = 2,    //!< Peripheral in USART mode on falling ed
 157:funsape/peripheral/usart0.hpp ****         SYNCHRONOUS_TX_FALLING_RX_RISING        = 3,    //!< Peripheral in USART mode on rising edg
 158:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_0                       = 4,    //!< Peripheral in master SPI mode 0.
 159:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_1                       = 5,    //!< Peripheral in master SPI mode 1.
 160:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_2                       = 6,    //!< Peripheral in master SPI mode 2.
 161:funsape/peripheral/usart0.hpp ****         MASTER_SPI_MODE_3                       = 7,    //!< Peripheral in master SPI mode 3.
 162:funsape/peripheral/usart0.hpp ****     };
 163:funsape/peripheral/usart0.hpp **** 
 164:funsape/peripheral/usart0.hpp ****     //     ///////////////    USART0 Reception Error     ////////////////     //
 165:funsape/peripheral/usart0.hpp ****     //!
 166:funsape/peripheral/usart0.hpp ****     //! \brief      USART0 Reception Error enumeration.
 167:funsape/peripheral/usart0.hpp ****     //! \details    Reception error associated with the USART0.
 168:funsape/peripheral/usart0.hpp ****     //! \warning    The value associate with the symbolic names may change
 169:funsape/peripheral/usart0.hpp ****     //!                 between builds and might not reflect the register/bits
 170:funsape/peripheral/usart0.hpp ****     //!                 real values. In order to ensure compatibility between
 171:funsape/peripheral/usart0.hpp ****     //!                 builds, always refer to the SYMBOLIC NAME, instead of
 172:funsape/peripheral/usart0.hpp ****     //!                 the VALUE.
 173:funsape/peripheral/usart0.hpp ****     //!
 174:funsape/peripheral/usart0.hpp ****     enum class ReceptionError : uint8_t {
 175:funsape/peripheral/usart0.hpp ****         NONE                            = 0,            //!< No reception errors occurred.
 176:funsape/peripheral/usart0.hpp ****         FRAME_ERROR                     = (1 << 0),     //!< Frame format invalid.
GAS LISTING /tmp/ccOPlziU.s 			page 70


 177:funsape/peripheral/usart0.hpp ****         PARITY_ERROR                    = (1 << 1),     //!< Parity check failed.
 178:funsape/peripheral/usart0.hpp ****         DATA_OVERRUN_ERROR              = (1 << 2),     //!< Data lost.
 179:funsape/peripheral/usart0.hpp ****         ALL                             = (1 << 0) | (1 << 1) | (1 << 2) //!< All errors
 180:funsape/peripheral/usart0.hpp ****     };
