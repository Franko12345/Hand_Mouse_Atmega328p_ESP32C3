 437:main.cpp      **** uint32_t micros() {
 438:main.cpp      ****     uint32_t overflows;
 439:main.cpp      ****     uint16_t ticks;
 440:main.cpp      **** 
 441:main.cpp      ****     // Disable interrupts briefly to ensure atomic read of 16-bit register and 32-bit counter
 442:main.cpp      ****     cli();
 443:main.cpp      ****     overflows = timer1_overflows;
GAS LISTING /tmp/ccUMk0PR.s 			page 9


 444:main.cpp      ****     ticks = timer1.getCounterValue();;
 445:main.cpp      ****     
 446:main.cpp      ****     // Check if an overflow just occurred but hasn't been handled yet
 447:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 448:main.cpp      ****         overflows++;
 449:main.cpp      ****         ticks = timer1.getCounterValue(); // Re-read to guarantee accurate timing
 450:main.cpp      ****     }
 451:main.cpp      ****     sei();
 452:main.cpp      **** 
 453:main.cpp      ****     // Each overflow is 65536 ticks. Each tick is 0.5 microseconds.
 454:main.cpp      ****     // Total microseconds = (overflows * 65536 * 0.5) + (ticks * 0.5)
 455:main.cpp      ****     return (overflows * 32768) + (ticks >> 1);
 456:main.cpp      **** }
 457:main.cpp      **** 
 458:main.cpp      **** uint32_t get_millis() {
 459:main.cpp      ****     uint32_t overflows;
 460:main.cpp      ****     uint16_t ticks;
 461:main.cpp      **** 
 462:main.cpp      ****     cli();
 463:main.cpp      ****     overflows = timer1_overflows;
 464:main.cpp      ****     ticks = timer1.getCounterValue();
 465:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 466:main.cpp      ****         overflows++;
 467:main.cpp      ****         ticks = timer1.getCounterValue();
 468:main.cpp      ****     }
 469:main.cpp      ****     sei();
 470:main.cpp      **** 
 471:main.cpp      ****     // Em vez de calcular microssegundos, calculamos direto o milissegundo aproximado.
 472:main.cpp      ****     // 32768 / 1024 = 32 (Exato!) -> overflows * 32
 473:main.cpp      ****     // ticks / 2048 -> equivale a ticks >> 11
 474:main.cpp      ****     return (overflows * 32) + (ticks >> 11);
 475:main.cpp      **** }
