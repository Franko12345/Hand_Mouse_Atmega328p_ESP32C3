 185:funsape/peripheral/timer0.hpp ****     enum class ClockSource : uint8_t {
 186:funsape/peripheral/timer0.hpp ****         DISABLED = 0,           //!< Disables clock, timer is off.
 187:funsape/peripheral/timer0.hpp ****         PRESCALER_1 = 1,        //!< Disables prescaler, timer clock frequency will be equal to CPU
 188:funsape/peripheral/timer0.hpp ****         PRESCALER_8 = 2,        //!< Timer clock frequency will be CPU clock divided by 8.
 189:funsape/peripheral/timer0.hpp ****         PRESCALER_64 = 3,       //!< Timer clock frequency will be CPU clock divided by 64.
 190:funsape/peripheral/timer0.hpp ****         PRESCALER_256 = 4,      //!< Timer clock frequency will be CPU clock divided by 256.
 191:funsape/peripheral/timer0.hpp ****         PRESCALER_1024 = 5,     //!< Timer clock frequency will be CPU clock divided by 1024.
 192:funsape/peripheral/timer0.hpp ****         T0_FALLING_EDGE = 6,    //!< Timer clock will be based on the falling edge of a signal plac
 193:funsape/peripheral/timer0.hpp ****         T0_RISING_EDGE = 7      //!< Timer clock will be based on the rising edge of a signal place
 194:funsape/peripheral/timer0.hpp ****     };
