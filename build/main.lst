 438:main.cpp      **** uint32_t micros() {
 439:main.cpp      ****     uint32_t overflows;
 440:main.cpp      ****     uint16_t ticks;
 441:main.cpp      **** 
 442:main.cpp      ****     // Disable interrupts briefly to ensure atomic read of 16-bit register and 32-bit counter
 443:main.cpp      ****     cli();
GAS LISTING /tmp/cccbyXSL.s 			page 9


 444:main.cpp      ****     overflows = timer1_overflows;
 445:main.cpp      ****     ticks = timer1.getCounterValue();;
 446:main.cpp      ****     
 447:main.cpp      ****     // Check if an overflow just occurred but hasn't been handled yet
 448:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 449:main.cpp      ****         overflows++;
 450:main.cpp      ****         ticks = timer1.getCounterValue(); // Re-read to guarantee accurate timing
 451:main.cpp      ****     }
 452:main.cpp      ****     sei();
 453:main.cpp      **** 
 454:main.cpp      ****     // Each overflow is 65536 ticks. Each tick is 0.5 microseconds.
 455:main.cpp      ****     // Total microseconds = (overflows * 65536 * 0.5) + (ticks * 0.5)
 456:main.cpp      ****     return (overflows * 32768) + (ticks >> 1);
 457:main.cpp      **** }
 458:main.cpp      **** 
 459:main.cpp      **** uint32_t get_millis() {
 460:main.cpp      ****     uint32_t overflows;
 461:main.cpp      ****     uint16_t ticks;
 462:main.cpp      **** 
 463:main.cpp      ****     cli();
 464:main.cpp      ****     overflows = timer1_overflows;
 465:main.cpp      ****     ticks = timer1.getCounterValue();
 466:main.cpp      ****     if ((TIFR1 & (1 << TOV1)) && (ticks < 65535)) {
 467:main.cpp      ****         overflows++;
 468:main.cpp      ****         ticks = timer1.getCounterValue();
 469:main.cpp      ****     }
 470:main.cpp      ****     sei();
 471:main.cpp      **** 
 472:main.cpp      ****     // Em vez de calcular microssegundos, calculamos direto o milissegundo aproximado.
 473:main.cpp      ****     // 32768 / 1024 = 32 (Exato!) -> overflows * 32
 474:main.cpp      ****     // ticks / 2048 -> equivale a ticks >> 11
 475:main.cpp      ****     return (overflows * 32) + (ticks >> 11);
 476:main.cpp      **** }
