 420:funsape/device/ssd1306.cpp ****     }
 421:funsape/device/ssd1306.cpp **** 
 422:funsape/device/ssd1306.cpp ****     // Direct mode: nothing to flush (no-op success)
 423:funsape/device/ssd1306.cpp ****     if(!this->_buffered) {
 424:funsape/device/ssd1306.cpp ****         this->_lastError = Error::NONE;
 425:funsape/device/ssd1306.cpp ****         debugMessage(Error::NONE, Debug::CodeIndex::SSD1306_MODULE);
