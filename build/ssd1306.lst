 410:funsape/device/ssd1306.cpp **** bool_t Ssd1306::display(void)
 411:funsape/device/ssd1306.cpp **** {
 412:funsape/device/ssd1306.cpp ****     // Mark passage for debugging purpose
 413:funsape/device/ssd1306.cpp ****     debugMark(PSTR("Ssd1306::display(void)"), Debug::CodeIndex::SSD1306_MODULE);
 414:funsape/device/ssd1306.cpp **** 
 415:funsape/device/ssd1306.cpp ****     // Check for errors
 416:funsape/device/ssd1306.cpp ****     if(!this->_isInitialized()) {
 417:funsape/device/ssd1306.cpp ****         // Returns error
 418:funsape/device/ssd1306.cpp ****         debugMessage(this->_lastError, Debug::CodeIndex::SSD1306_MODULE);
