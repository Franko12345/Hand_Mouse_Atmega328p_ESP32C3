 759:funsape/device/ssd1306.cpp ****     // Local variables (Bresenham line algorithm)
 760:funsape/device/ssd1306.cpp ****     int16_t auxX0                       = x0_p;
 761:funsape/device/ssd1306.cpp ****     int16_t auxY0                       = y0_p;
