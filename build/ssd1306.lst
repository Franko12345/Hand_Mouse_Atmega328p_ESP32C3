 346:funsape/device/ssd1306.cpp **** bool_t Ssd1306::clearScreen(void)
 347:funsape/device/ssd1306.cpp **** {
 348:funsape/device/ssd1306.cpp ****     // Mark passage for debugging purpose
 349:funsape/device/ssd1306.cpp ****     debugMark(PSTR("Ssd1306::clearScreen(void)"), Debug::CodeIndex::SSD1306_MODULE);
 350:funsape/device/ssd1306.cpp **** 
 351:funsape/device/ssd1306.cpp ****     // Check for errors
 352:funsape/device/ssd1306.cpp ****     if(!this->_isInitialized()) {
 353:funsape/device/ssd1306.cpp ****         // Returns error
 354:funsape/device/ssd1306.cpp ****         debugMessage(this->_lastError, Debug::CodeIndex::SSD1306_MODULE);
 355:funsape/device/ssd1306.cpp ****         return false;
 356:funsape/device/ssd1306.cpp ****     }
 357:funsape/device/ssd1306.cpp **** 
 358:funsape/device/ssd1306.cpp ****     // Buffered mode: clears the RAM buffer and marks every page dirty
 359:funsape/device/ssd1306.cpp ****     // (the panel is only updated on the next display() call)
 360:funsape/device/ssd1306.cpp ****     if(this->_buffered) {
 361:funsape/device/ssd1306.cpp ****         uint16_t auxSize = (uint16_t)this->_pages * constSsd1306Width;
 362:funsape/device/ssd1306.cpp ****         for(uint16_t i = 0; i < auxSize; i++) {
 363:funsape/device/ssd1306.cpp ****             this->_frameBuffer[i] = 0x00;
 364:funsape/device/ssd1306.cpp ****         }
 365:funsape/device/ssd1306.cpp ****         this->_dirtyPageMask            = (uint8_t)((1 << this->_pages) - 1);
 366:funsape/device/ssd1306.cpp ****         this->_cursorX                  = 0;
 367:funsape/device/ssd1306.cpp ****         this->_cursorY                  = 0;
 368:funsape/device/ssd1306.cpp ****         this->_lastError = Error::NONE;
 369:funsape/device/ssd1306.cpp ****         debugMessage(Error::NONE, Debug::CodeIndex::SSD1306_MODULE);
 370:funsape/device/ssd1306.cpp ****         return true;
 371:funsape/device/ssd1306.cpp ****     }
 372:funsape/device/ssd1306.cpp **** 
 373:funsape/device/ssd1306.cpp ****     // Local variables
 374:funsape/device/ssd1306.cpp ****     uint8_t auxBuffer[constSsd1306DataChunk];
 375:funsape/device/ssd1306.cpp **** 
 376:funsape/device/ssd1306.cpp ****     // Prepares a blank chunk
GAS LISTING /tmp/cc7wpQ70.s 			page 10


 377:funsape/device/ssd1306.cpp ****     for(uint8_t i = 0; i < constSsd1306DataChunk; i++) {
 378:funsape/device/ssd1306.cpp ****         auxBuffer[i] = 0x00;
 379:funsape/device/ssd1306.cpp ****     }
 380:funsape/device/ssd1306.cpp **** 
 381:funsape/device/ssd1306.cpp ****     // Writes zeros to every page
 382:funsape/device/ssd1306.cpp ****     for(uint8_t page = 0; page < this->_pages; page++) {
 383:funsape/device/ssd1306.cpp ****         if(!this->_setAddress(page, 0)) {
 384:funsape/device/ssd1306.cpp ****             // Returns error
 385:funsape/device/ssd1306.cpp ****             debugMessage(this->_lastError, Debug::CodeIndex::SSD1306_MODULE);
 386:funsape/device/ssd1306.cpp ****             return false;
 387:funsape/device/ssd1306.cpp ****         }
 388:funsape/device/ssd1306.cpp ****         uint8_t remaining = constSsd1306Width;
 389:funsape/device/ssd1306.cpp ****         while(remaining > 0) {
 390:funsape/device/ssd1306.cpp ****             uint8_t chunk = (remaining > constSsd1306DataChunk) ? constSsd1306DataChunk : remaining
 391:funsape/device/ssd1306.cpp ****             if(!this->_writeData(auxBuffer, chunk)) {
 392:funsape/device/ssd1306.cpp ****                 // Returns error
 393:funsape/device/ssd1306.cpp ****                 debugMessage(this->_lastError, Debug::CodeIndex::SSD1306_MODULE);
 394:funsape/device/ssd1306.cpp ****                 return false;
 395:funsape/device/ssd1306.cpp ****             }
 396:funsape/device/ssd1306.cpp ****             remaining -= chunk;
 397:funsape/device/ssd1306.cpp ****         }
 398:funsape/device/ssd1306.cpp ****     }
 399:funsape/device/ssd1306.cpp **** 
 400:funsape/device/ssd1306.cpp ****     // Homes the text cursor
 401:funsape/device/ssd1306.cpp ****     this->_cursorX                      = 0;
 402:funsape/device/ssd1306.cpp ****     this->_cursorY                      = 0;
 403:funsape/device/ssd1306.cpp **** 
 404:funsape/device/ssd1306.cpp ****     // Returns successfully
 405:funsape/device/ssd1306.cpp ****     this->_lastError = Error::NONE;
 406:funsape/device/ssd1306.cpp ****     debugMessage(Error::NONE, Debug::CodeIndex::SSD1306_MODULE);
 407:funsape/device/ssd1306.cpp ****     return true;
 408:funsape/device/ssd1306.cpp **** }
