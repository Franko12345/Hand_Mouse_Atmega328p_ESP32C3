 763:funsape/device/ssd1306.cpp ****     int16_t auxDy                       = (y1_p >= y0_p) ? -(y1_p - y0_p) : -(y0_p - y1_p);
 764:funsape/device/ssd1306.cpp ****     int16_t auxSx                       = (x0_p < x1_p) ? 1 : -1;
 765:funsape/device/ssd1306.cpp ****     int16_t auxSy                       = (y0_p < y1_p) ? 1 : -1;
 766:funsape/device/ssd1306.cpp ****     int16_t auxErr                      = auxDx + auxDy;
 767:funsape/device/ssd1306.cpp **** 
 768:funsape/device/ssd1306.cpp ****     // Walks the line, one pixel at a time
 769:funsape/device/ssd1306.cpp ****     while(true) {
 770:funsape/device/ssd1306.cpp ****         this->_setPixel((uint8_t)auxX0, (uint8_t)auxY0, on_p);
 771:funsape/device/ssd1306.cpp ****         if((auxX0 == (int16_t)x1_p) && (auxY0 == (int16_t)y1_p)) {
 772:funsape/device/ssd1306.cpp ****             break;
 773:funsape/device/ssd1306.cpp ****         }
 774:funsape/device/ssd1306.cpp ****         int16_t auxErr2 = (int16_t)(2 * auxErr);
 775:funsape/device/ssd1306.cpp ****         if(auxErr2 >= auxDy) {
 776:funsape/device/ssd1306.cpp ****             auxErr                      += auxDy;
 777:funsape/device/ssd1306.cpp ****             auxX0                       += auxSx;
 778:funsape/device/ssd1306.cpp ****         }
 779:funsape/device/ssd1306.cpp ****         if(auxErr2 <= auxDx) {
 780:funsape/device/ssd1306.cpp ****             auxErr                      += auxDx;
 781:funsape/device/ssd1306.cpp ****             auxY0                       += auxSy;
 782:funsape/device/ssd1306.cpp ****         }
 783:funsape/device/ssd1306.cpp ****     }
 784:funsape/device/ssd1306.cpp **** 
 785:funsape/device/ssd1306.cpp ****     // Returns successfully
 786:funsape/device/ssd1306.cpp ****     this->_lastError = Error::NONE;
 787:funsape/device/ssd1306.cpp ****     debugMessage(Error::NONE, Debug::CodeIndex::SSD1306_MODULE);
 788:funsape/device/ssd1306.cpp ****     return true;
 789:funsape/device/ssd1306.cpp **** }
