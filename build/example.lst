 215:funsape/globalDefines.hpp **** //!
 216:funsape/globalDefines.hpp **** //! @addtogroup     Bit_Handling
 217:funsape/globalDefines.hpp **** //! @details        Performs bitwise operations in one bit of a variable or
 218:funsape/globalDefines.hpp **** //!                     register.
 219:funsape/globalDefines.hpp **** //! @{
 220:funsape/globalDefines.hpp **** //!
 221:funsape/globalDefines.hpp **** 
 222:funsape/globalDefines.hpp **** //     //////////////////////     BIT HANDLING     //////////////////////     //
 223:funsape/globalDefines.hpp **** 
 224:funsape/globalDefines.hpp **** #ifndef clrBit
 225:funsape/globalDefines.hpp **** //!
 226:funsape/globalDefines.hpp **** //! @def            clrBit(reg, pos)
 227:funsape/globalDefines.hpp **** //! @details        Clears the bit at position @a pos of the register or
 228:funsape/globalDefines.hpp **** //!                     variable @a reg.
 229:funsape/globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 230:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be cleared
 231:funsape/globalDefines.hpp **** //!
 232:funsape/globalDefines.hpp **** #   define clrBit(reg, pos)             do{     \
 233:funsape/globalDefines.hpp ****         (reg) &= ~(1 << (pos));                 \
 234:funsape/globalDefines.hpp ****     }while(0)
 235:funsape/globalDefines.hpp **** #endif
 236:funsape/globalDefines.hpp **** 
 237:funsape/globalDefines.hpp **** #ifndef cplBit
 238:funsape/globalDefines.hpp **** //!
 239:funsape/globalDefines.hpp **** //! @def            cplBit(reg, pos)
 240:funsape/globalDefines.hpp **** //! @details        Complements (invert) the bit at position @a pos of the
 241:funsape/globalDefines.hpp **** //!                     register or variable @a reg.
 242:funsape/globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 243:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be complemented
 244:funsape/globalDefines.hpp **** //!
 245:funsape/globalDefines.hpp **** #   define cplBit(reg, pos)             do{     \
 246:funsape/globalDefines.hpp ****         (reg) ^= (1 << (pos));                  \
 247:funsape/globalDefines.hpp ****     }while(0)
 248:funsape/globalDefines.hpp **** #endif
 249:funsape/globalDefines.hpp **** 
 250:funsape/globalDefines.hpp **** #ifndef setBit
 251:funsape/globalDefines.hpp **** //!
 252:funsape/globalDefines.hpp **** //! @def            setBit(reg, pos)
 253:funsape/globalDefines.hpp **** //! @details        Sets the bit at position @a pos of the register or variable
 254:funsape/globalDefines.hpp **** //!                     @a reg.
 255:funsape/globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 256:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be set
 257:funsape/globalDefines.hpp **** //!
 258:funsape/globalDefines.hpp **** #   define setBit(reg, pos)             do{     \
 259:funsape/globalDefines.hpp ****         (reg) |= (1 << (pos));                  \
 260:funsape/globalDefines.hpp ****     }while(0)
 261:funsape/globalDefines.hpp **** #endif
 262:funsape/globalDefines.hpp **** 
 263:funsape/globalDefines.hpp **** //     ///////////////////////     BIT TESTING    ///////////////////////     //
 264:funsape/globalDefines.hpp **** 
 265:funsape/globalDefines.hpp **** #ifndef isBitClr
 266:funsape/globalDefines.hpp **** //!
 267:funsape/globalDefines.hpp **** //! @def            isBitClr(reg, pos)
 268:funsape/globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 269:funsape/globalDefines.hpp **** //!                     variable @a reg is cleared.
GAS LISTING /tmp/cch7C0sd.s 			page 10


 270:funsape/globalDefines.hpp **** //! @param[in]      reg                 register or variable
 271:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 272:funsape/globalDefines.hpp **** //! @retval         true                if the bit is cleared
 273:funsape/globalDefines.hpp **** //! @retval         false               if the bit is set
 274:funsape/globalDefines.hpp **** //!
 275:funsape/globalDefines.hpp **** #   define isBitClr(reg, pos)           (bool_t)(!isBitSet(reg,pos))
 276:funsape/globalDefines.hpp **** #endif
 277:funsape/globalDefines.hpp **** 
 278:funsape/globalDefines.hpp **** #ifndef isBitSet
 279:funsape/globalDefines.hpp **** //!
 280:funsape/globalDefines.hpp **** //! @def            isBitSet(reg, pos)
 281:funsape/globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 282:funsape/globalDefines.hpp **** //!                     variable @a reg is set.
 283:funsape/globalDefines.hpp **** //! @param[in]      reg                 register or variable
 284:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 285:funsape/globalDefines.hpp **** //! @retval         true                if the bit is set
 286:funsape/globalDefines.hpp **** //! @retval         false               if the bit is cleared
 287:funsape/globalDefines.hpp **** //!
 288:funsape/globalDefines.hpp **** #   define isBitSet(reg, pos)           (bool_t)(((reg) >> (pos)) & 1)
 289:funsape/globalDefines.hpp **** #endif
 290:funsape/globalDefines.hpp **** 
 291:funsape/globalDefines.hpp **** //     ///////////////////////     BIT LOOPING    ///////////////////////     //
 292:funsape/globalDefines.hpp **** 
 293:funsape/globalDefines.hpp **** #ifndef waitUntilBitIsClear
 294:funsape/globalDefines.hpp **** //!
 295:funsape/globalDefines.hpp **** //! @def            waitUntilBitIsClear(reg, pos)
 296:funsape/globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 297:funsape/globalDefines.hpp **** //!                     in register or variable @a reg is set.
 298:funsape/globalDefines.hpp **** //! @param[in]      reg                 register or variable
 299:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 300:funsape/globalDefines.hpp **** //!
 301:funsape/globalDefines.hpp **** #   define waitUntilBitIsClear(reg, pos)        do{     \
 302:funsape/globalDefines.hpp ****         doNothing();                                    \
 303:funsape/globalDefines.hpp ****     }while(isBitSet((reg), (pos)))
 304:funsape/globalDefines.hpp **** #endif
 305:funsape/globalDefines.hpp **** 
 306:funsape/globalDefines.hpp **** #ifndef waitUntilBitIsSet
 307:funsape/globalDefines.hpp **** //!
 308:funsape/globalDefines.hpp **** //! @def            waitUntilBitIsSet(reg, pos)
 309:funsape/globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 310:funsape/globalDefines.hpp **** //!                     in register or variable @a reg is cleared.
 311:funsape/globalDefines.hpp **** //! @param[in]      reg                 register or variable
 312:funsape/globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 313:funsape/globalDefines.hpp **** //!
 314:funsape/globalDefines.hpp **** #   define waitUntilBitIsSet(reg, pos)  do{     \
 315:funsape/globalDefines.hpp ****         doNothing();                            \
 316:funsape/globalDefines.hpp ****     } while (isBitClr((reg), (pos)))
 317:funsape/globalDefines.hpp **** #endif
 318:funsape/globalDefines.hpp **** 
