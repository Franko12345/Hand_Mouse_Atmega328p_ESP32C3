 356:funsape/globalDefines.hpp **** //!
 357:funsape/globalDefines.hpp **** //! @def            cplMask(reg, mask)
 358:funsape/globalDefines.hpp **** //! @details        Complements (inverts) the bits of the register or variable
 359:funsape/globalDefines.hpp **** //!                     @a reg that are set on the supplied mask @a mask.
 360:funsape/globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 361:funsape/globalDefines.hpp **** //! @param[in]      mask                one-mask of the bits to be complemented
 362:funsape/globalDefines.hpp **** //!
