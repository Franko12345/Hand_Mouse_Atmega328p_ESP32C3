 848:funsape/globalDefines.hpp **** //! @details        Returns the greater value between @a var1 and @a var2.
 849:funsape/globalDefines.hpp **** //! @param[in]      var1                first value
 850:funsape/globalDefines.hpp **** //! @param[in]      var2                second value
 851:funsape/globalDefines.hpp **** //! @return         the greater value between @a var1 and @a var2
 852:funsape/globalDefines.hpp **** //!
 853:funsape/globalDefines.hpp **** #define getMaximumOf(var1, var2)        (       \
 854:funsape/globalDefines.hpp ****         ((var1) > (var2))                       \
 855:funsape/globalDefines.hpp ****         ? (var1)                                \
 856:funsape/globalDefines.hpp ****         : (var2)                                \
 857:funsape/globalDefines.hpp **** )
 858:funsape/globalDefines.hpp **** 
 859:funsape/globalDefines.hpp **** //!
 860:funsape/globalDefines.hpp **** //! @def            getMinimumOf(var1, var2)
 861:funsape/globalDefines.hpp **** //! @details        Returns the lower value between @a var1 and @a var2.
 862:funsape/globalDefines.hpp **** //! @param[in]      var1                first value
 863:funsape/globalDefines.hpp **** //! @param[in]      var2                second value
 864:funsape/globalDefines.hpp **** //! @return         the lower value between @a var1 and @a var2
 865:funsape/globalDefines.hpp **** //!
 866:funsape/globalDefines.hpp **** #define getMinimumOf(var1, var2)        (       \
 867:funsape/globalDefines.hpp ****         ((var1) < (var2))                       \
 868:funsape/globalDefines.hpp ****         ? (var1)                                \
 869:funsape/globalDefines.hpp ****         : (var2)                                \
 870:funsape/globalDefines.hpp **** )
 871:funsape/globalDefines.hpp **** 
 872:funsape/globalDefines.hpp **** //!
 873:funsape/globalDefines.hpp **** //! @def            truncateBetween(var, min, max)
 874:funsape/globalDefines.hpp **** //! @details        Truncates (trims) the value between maximum and minimum
 875:funsape/globalDefines.hpp **** //!                     values.
 876:funsape/globalDefines.hpp **** //! @warning        The macro-function will not work correctly if @a min is
 877:funsape/globalDefines.hpp **** //!                     greater than @a max.
 878:funsape/globalDefines.hpp **** //! @param[in]      var                 value to be truncated
 879:funsape/globalDefines.hpp **** //! @param[in]      max                 maximum allowed value
 880:funsape/globalDefines.hpp **** //! @param[in]      min                 minimum allowed value
 881:funsape/globalDefines.hpp **** //! @return         @a min              if the value is lower than @a min
 882:funsape/globalDefines.hpp **** //! @return         @a max              if the value is greater than @a max
 883:funsape/globalDefines.hpp **** //! @return         @a var              if the value is placed between @a min
 884:funsape/globalDefines.hpp **** //!                                          and @a max
 885:funsape/globalDefines.hpp **** //!
 886:funsape/globalDefines.hpp **** #define truncateBetween(var, min, max)  (       \
 887:funsape/globalDefines.hpp ****         ((var) < (min))                         \
 888:funsape/globalDefines.hpp ****         ? (min)                                 \
 889:funsape/globalDefines.hpp ****         : (((var) > (max))                      \
 890:funsape/globalDefines.hpp ****                 ? (max)                         \
 891:funsape/globalDefines.hpp ****                 : (var)                         \
 892:funsape/globalDefines.hpp ****         )                                       \
 893:funsape/globalDefines.hpp **** )
 894:funsape/globalDefines.hpp **** 
