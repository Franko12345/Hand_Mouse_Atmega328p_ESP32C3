 384:funsape/globalDefines.hpp **** //!
 385:funsape/globalDefines.hpp **** //! @def            clrMaskOffset(reg, mask, offset)
 386:funsape/globalDefines.hpp **** //! @details        Clears the bits of the register or variable @a reg that are
 387:funsape/globalDefines.hpp **** //!                     set on the supplied mask @a mask. The mask is first
 388:funsape/globalDefines.hpp **** //!                     left-shifted by the value given in @a offset.
 389:funsape/globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 390:funsape/globalDefines.hpp **** //! @param[in]      mask                one-mask of the bits to be cleared
