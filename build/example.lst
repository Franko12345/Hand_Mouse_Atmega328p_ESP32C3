 503:funsape/globalDefines.hpp **** 
 504:funsape/globalDefines.hpp **** //     /////////////     DATA MANIPULATION (8-BITS WIDE)    /////////////     //
 505:funsape/globalDefines.hpp **** 
 506:funsape/globalDefines.hpp **** //!
 507:funsape/globalDefines.hpp **** //! @def            byteGetNibble1(dataByte)
 508:funsape/globalDefines.hpp **** //! @details        Returns the nibble 1 of the given @a dataByte byte.
 509:funsape/globalDefines.hpp **** //! @param[in]      dataByte            variable
 510:funsape/globalDefines.hpp **** //! @return         @a dataByte nibble 1, shifted to bit position 0
 511:funsape/globalDefines.hpp **** //!
 512:funsape/globalDefines.hpp **** #define byteGetNibble1(dataByte)        (       \
 513:funsape/globalDefines.hpp ****         ((dataByte) >> 4) & 0x0F                \
 514:funsape/globalDefines.hpp **** )
