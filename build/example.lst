 122:/usr/avr/include/util/delay.h **** /**
 123:/usr/avr/include/util/delay.h ****    \ingroup util_delay
 124:/usr/avr/include/util/delay.h **** 
 125:/usr/avr/include/util/delay.h ****    Perform a delay of \c __ms milliseconds.
 126:/usr/avr/include/util/delay.h **** 
 127:/usr/avr/include/util/delay.h ****    The macro #F_CPU is supposed to be defined to a
 128:/usr/avr/include/util/delay.h ****    constant defining the CPU clock frequency in Hertz.
 129:/usr/avr/include/util/delay.h **** 
 130:/usr/avr/include/util/delay.h **** -  If \c __builtin_avr_delay_cycles() is
 131:/usr/avr/include/util/delay.h **** \if GIT_BRANCH_IS_ONLINEDOCS
 132:/usr/avr/include/util/delay.h ****    supported
 133:/usr/avr/include/util/delay.h **** \else
 134:/usr/avr/include/util/delay.h ****    \ref faq_toolchain_support "supported"
 135:/usr/avr/include/util/delay.h **** \endif
 136:/usr/avr/include/util/delay.h ****    by the compiler, then
 137:/usr/avr/include/util/delay.h ****    the maximal possible delay is 4294967.04 / f<sub>CPU</sub> milliseconds
 138:/usr/avr/include/util/delay.h ****    where f<sub>CPU</sub> denotes the CPU frequency in units of 1 MHz.
 139:/usr/avr/include/util/delay.h ****    This is around 71 minutes / f<sub>CPU</sub>.
 140:/usr/avr/include/util/delay.h ****    Values greater than that are saturated to this value.
 141:/usr/avr/include/util/delay.h **** 
 142:/usr/avr/include/util/delay.h **** -  Otherwise, _delay_loop_2() is used as a fallback, and the maximal
 143:/usr/avr/include/util/delay.h ****    possible delay is 262.14 / f<sub>CPU</sub> milliseconds.
 144:/usr/avr/include/util/delay.h ****    When the user requests a delay which exceeds the maximum possible one,
 145:/usr/avr/include/util/delay.h ****    _delay_ms() provides a decreased resolution functionality. In this
 146:/usr/avr/include/util/delay.h ****    mode _delay_ms() will work with a resolution of 1/10&nbsp;ms, providing
 147:/usr/avr/include/util/delay.h ****    delays up to 6.5535 seconds (independent from CPU frequency).  The
 148:/usr/avr/include/util/delay.h ****    user will not be informed about decreased resolution.
 149:/usr/avr/include/util/delay.h **** .
 150:/usr/avr/include/util/delay.h **** 
 151:/usr/avr/include/util/delay.h ****    Conversion of \c __ms into clock cycles may not always result in
 152:/usr/avr/include/util/delay.h ****    an integral value.  By default, the clock cycles are rounded up to the next
 153:/usr/avr/include/util/delay.h ****    integer. This ensures that the user gets at least \c __ms
 154:/usr/avr/include/util/delay.h ****    microseconds of delay.
