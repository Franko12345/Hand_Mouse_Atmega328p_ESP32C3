 159:funsape/globalDefines.hpp **** //!
 160:funsape/globalDefines.hpp **** //! @def            isGpioAddressValid(gpioPort)
 161:funsape/globalDefines.hpp **** //! @details        Checks if the given parameter @a gpioPort is a valid GPIO
 162:funsape/globalDefines.hpp **** //!                     port address. Valid GPIO addresses are @c DDRx, @c PORTx
 163:funsape/globalDefines.hpp **** //!                     and @c PINx register addresses.
 164:funsape/globalDefines.hpp **** //! @param[in]      gpioPort            GPIO port address
 165:funsape/globalDefines.hpp **** //! @retval         true                if GPIO address is valid
 166:funsape/globalDefines.hpp **** //! @retval         false               if GPIO address is not valid
 167:funsape/globalDefines.hpp **** //!
 168:funsape/globalDefines.hpp **** #define isGpioAddressValid(gpioPort)    (bool_t)(       \
 169:funsape/globalDefines.hpp ****         (IS_GPIO_ALL_INSTANCE(gpioPort))                \
