 468:funsape/globalDefines.hpp **** //!
 469:funsape/globalDefines.hpp **** #define cplIoPin(portAddress, portPin)          do{             \
 470:funsape/globalDefines.hpp ****         cplBit(*(getGpioPortAddress(portAddress)), portPin);    \
 471:funsape/globalDefines.hpp ****     } while(0)
 472:funsape/globalDefines.hpp **** 
