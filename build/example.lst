   1:example.cpp   **** //!
   2:example.cpp   **** //! \file           example.cpp_
   3:example.cpp   **** //! \brief          Exemplo minimo: mostrar texto no OLED SSD1306 (I2C) com a FunSAPE
   4:example.cpp   **** //! \details        Mostra um texto por alguns segundos e depois troca o texto,
   5:example.cpp   **** //!                     repetindo indefinidamente.
   6:example.cpp   **** //!
   7:example.cpp   **** //!                 Ligacao no ATmega328p: SDA = A4/PC4, SCL = A5/PC5 (com pull-ups
   8:example.cpp   **** //!                     no barramento). Endereco I2C padrao do modulo: 0x3C.
   9:example.cpp   **** //!
  10:example.cpp   **** //!                 Obs.: o nome termina em ".cpp_" de proposito para NAO entrar no
  11:example.cpp   **** //!                     build (o Makefile compila todo "*.cpp"). Para usar, renomeie
  12:example.cpp   **** //!                     para "example.cpp" e garanta que exista apenas um main() no
  13:example.cpp   **** //!                     projeto (ex.: mova/renomeie o main.cpp atual).
  14:example.cpp   **** //!
  15:example.cpp   **** 
  16:example.cpp   **** #define F_CPU 16000000UL
  17:example.cpp   **** 
  18:example.cpp   **** #include "funsape/globalDefines.hpp"
  19:example.cpp   **** #include "funsape/peripheral/twi.hpp"
  20:example.cpp   **** #include "funsape/device/ssd1306.hpp"
  21:example.cpp   **** 
  22:example.cpp   **** // Objeto global do display
  23:example.cpp   **** Ssd1306 display;
  24:example.cpp   **** 
  25:example.cpp   **** int main(void)
  26:example.cpp   **** {
  27:example.cpp   ****     // Configura o barramento I2C (TWI) a 400 kHz com buffer de 64 bytes
  28:example.cpp   ****     twi.init(400000, 64);
  29:example.cpp   **** 
  30:example.cpp   ****     // O TWI e' orientado a interrupcao -> habilita interrupcoes globais
  31:example.cpp   ****     sei();
  32:example.cpp   **** 
  33:example.cpp   ****     // Inicializa o OLED 128x64 no endereco 0x3C (padrao)
  34:example.cpp   ****     display.init(&twi);
  35:example.cpp   **** 
  36:example.cpp   ****     while(true) {
  37:example.cpp   ****         // --- Primeiro texto ---
  38:example.cpp   ****         display.clearScreen();
  39:example.cpp   ****         display.setTextSize(1);
  40:example.cpp   ****         display.setCursor(0, 0);
  41:example.cpp   ****         display.print("Ola, mundo!");
  42:example.cpp   ****         display.setTextSize(2);
  43:example.cpp   ****         display.setCursor(0, 2);
  44:example.cpp   ****         display.print("FunSAPE");
GAS LISTING /tmp/cch7C0sd.s 			page 2


  45:example.cpp   **** 
  46:example.cpp   ****         delayMs(2000);              // mantem na tela por 2 segundos
  47:example.cpp   **** 
  48:example.cpp   ****         // --- Segundo texto ---
  49:example.cpp   ****         display.clearScreen();
  50:example.cpp   ****         display.setTextSize(1);
  51:example.cpp   ****         display.setCursor(0, 0);
  52:example.cpp   ****         display.print("Texto mudou :)");
  53:example.cpp   ****         display.setTextSize(2);
  54:example.cpp   ****         display.setCursor(0, 3);
  55:example.cpp   ****         display.print("SSD1306");
  56:example.cpp   **** 
  57:example.cpp   ****         delayMs(2000);              // mantem na tela por 2 segundos
  58:example.cpp   ****     }
  59:example.cpp   **** 
  60:example.cpp   ****     return 0;
  61:example.cpp   **** }
