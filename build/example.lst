 498:funsape/globalDefines.hpp **** //! @addtogroup     Data_Handling
 499:funsape/globalDefines.hpp **** //! @details        Performs general data handling, shifting and swapping a
 500:funsape/globalDefines.hpp **** //!                      variable data.
 501:funsape/globalDefines.hpp **** //! @{
