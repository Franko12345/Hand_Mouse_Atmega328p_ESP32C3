 449:funsape/globalDefines.hpp **** //!
 450:funsape/globalDefines.hpp **** //! @def            clrIoPin(portAddress, portPin)
 451:funsape/globalDefines.hpp **** //! @brief          Clears a GPIO pin.
 452:funsape/globalDefines.hpp **** //! @details        Clears the bit corresponding to @a portPin in the port
 453:funsape/globalDefines.hpp **** //!                     register pointed to by @a portAddress.
 454:funsape/globalDefines.hpp **** //! @param[in,out]  portAddress         address of the GPIO port (e.g., &PORTB)
 455:funsape/globalDefines.hpp **** //! @param[in]      portPin             index of the pin (0-7)
 456:funsape/globalDefines.hpp **** //!
 457:funsape/globalDefines.hpp **** #define clrIoPin(portAddress, portPin)          do{             \
 458:funsape/globalDefines.hpp ****         clrBit(*(getGpioPortAddress(portAddress)), portPin);    \
 459:funsape/globalDefines.hpp ****     } while(0)
 460:funsape/globalDefines.hpp **** 
 461:funsape/globalDefines.hpp **** //!
 462:funsape/globalDefines.hpp **** //! @def            cplIoPin(portAddress, portPin)
 463:funsape/globalDefines.hpp **** //! @brief          Toggles a GPIO pin.
 464:funsape/globalDefines.hpp **** //! @details        Complements the bit corresponding to @a portPin in the port
 465:funsape/globalDefines.hpp **** //!                     register pointed to by @a portAddress.
 466:funsape/globalDefines.hpp **** //! @param[in,out]  portAddress         address of the GPIO port (e.g., &PORTB)
