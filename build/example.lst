1305:funsape/globalDefines.hpp **** // Implementation of bitwise operators for Axis enum class to allow mask
1306:funsape/globalDefines.hpp **** //      combinations.
1307:funsape/globalDefines.hpp **** 
1308:funsape/globalDefines.hpp **** Axis inlined operator|(Axis a, Axis b)
1309:funsape/globalDefines.hpp **** {
1310:funsape/globalDefines.hpp ****     return static_cast<Axis>(static_cast<uint8_t>(a) | static_cast<uint8_t>(b));
1311:funsape/globalDefines.hpp **** }
1312:funsape/globalDefines.hpp **** 
1313:funsape/globalDefines.hpp **** Axis inlined &operator|=(Axis &a, Axis b)
1314:funsape/globalDefines.hpp **** {
1315:funsape/globalDefines.hpp ****     return a = static_cast<Axis>(static_cast<uint8_t>(a) | static_cast<uint8_t>(b));
1316:funsape/globalDefines.hpp **** }
1317:funsape/globalDefines.hpp **** 
1318:funsape/globalDefines.hpp **** Axis inlined operator&(Axis a, Axis b)
1319:funsape/globalDefines.hpp **** {
1320:funsape/globalDefines.hpp ****     return static_cast<Axis>(static_cast<uint8_t>(a) & static_cast<uint8_t>(b));
1321:funsape/globalDefines.hpp **** }
1322:funsape/globalDefines.hpp **** 
1323:funsape/globalDefines.hpp **** Axis inlined &operator&=(Axis &a, Axis b)
1324:funsape/globalDefines.hpp **** {
1325:funsape/globalDefines.hpp ****     return a = static_cast<Axis>(static_cast<uint8_t>(a) & static_cast<uint8_t>(b));
1326:funsape/globalDefines.hpp **** }
