  29:funsape/util/intTrig.cpp **** 
  30:funsape/util/intTrig.cpp **** //     Converts a first-quadrant angle in millidegrees [0..90000] into a table
  31:funsape/util/intTrig.cpp **** //     position in Q8 over 128 intervals:  pos = (angle * SCALE) >> 16, with
  32:funsape/util/intTrig.cpp **** //     SCALE = round(32768 / 90000 * 65536) = 23860. This avoids any division.
  33:funsape/util/intTrig.cpp **** cuint16_t constIntTrigScale             = 23860;
  34:funsape/util/intTrig.cpp **** 
  35:funsape/util/intTrig.cpp **** cint32_t constIntTrigQuarterTurn        = 90000L;   //  90 degrees, in millidegrees
  36:funsape/util/intTrig.cpp **** cint32_t constIntTrigHalfTurn           = 180000L;  // 180 degrees, in millidegrees
  37:funsape/util/intTrig.cpp **** cint32_t constIntTrigFullTurn           = 360000L;  // 360 degrees, in millidegrees
  38:funsape/util/intTrig.cpp **** 
  39:funsape/util/intTrig.cpp **** //     Quarter-wave sine table, Q15 (value = sin(k * 90/128 degrees) * 32768).
  40:funsape/util/intTrig.cpp **** //     129 entries (k = 0..128), 258 bytes in flash, 0 bytes in RAM.
  41:funsape/util/intTrig.cpp **** static const int16_t constSinTable[129] PROGMEM = {
  42:funsape/util/intTrig.cpp ****          0,    402,    804,   1206,   1608,   2009,   2410,   2811,
