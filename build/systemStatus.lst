 865:funsape/util/../globalDefines.hpp **** //!
 866:funsape/util/../globalDefines.hpp **** #define getMinimumOf(var1, var2)        (       \
 867:funsape/util/../globalDefines.hpp ****         ((var1) < (var2))                       \
 868:funsape/util/../globalDefines.hpp ****         ? (var1)                                \
 869:funsape/util/../globalDefines.hpp ****         : (var2)                                \
 870:funsape/util/../globalDefines.hpp **** )
