 258:funsape/util/../globalDefines.hpp **** #   define setBit(reg, pos)             do{     \
 259:funsape/util/../globalDefines.hpp ****         (reg) |= (1 << (pos));                  \
 260:funsape/util/../globalDefines.hpp ****     }while(0)
 261:funsape/util/../globalDefines.hpp **** #endif
 262:funsape/util/../globalDefines.hpp **** 
 263:funsape/util/../globalDefines.hpp **** //     ///////////////////////     BIT TESTING    ///////////////////////     //
 264:funsape/util/../globalDefines.hpp **** 
 265:funsape/util/../globalDefines.hpp **** #ifndef isBitClr
 266:funsape/util/../globalDefines.hpp **** //!
 267:funsape/util/../globalDefines.hpp **** //! @def            isBitClr(reg, pos)
 268:funsape/util/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 269:funsape/util/../globalDefines.hpp **** //!                     variable @a reg is cleared.
 270:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 271:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 272:funsape/util/../globalDefines.hpp **** //! @retval         true                if the bit is cleared
 273:funsape/util/../globalDefines.hpp **** //! @retval         false               if the bit is set
 274:funsape/util/../globalDefines.hpp **** //!
 275:funsape/util/../globalDefines.hpp **** #   define isBitClr(reg, pos)           (bool_t)(!isBitSet(reg,pos))
 276:funsape/util/../globalDefines.hpp **** #endif
 277:funsape/util/../globalDefines.hpp **** 
 278:funsape/util/../globalDefines.hpp **** #ifndef isBitSet
 279:funsape/util/../globalDefines.hpp **** //!
 280:funsape/util/../globalDefines.hpp **** //! @def            isBitSet(reg, pos)
 281:funsape/util/../globalDefines.hpp **** //! @details        Verifies if the bit at position @a pos at the register or
 282:funsape/util/../globalDefines.hpp **** //!                     variable @a reg is set.
 283:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 284:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 285:funsape/util/../globalDefines.hpp **** //! @retval         true                if the bit is set
 286:funsape/util/../globalDefines.hpp **** //! @retval         false               if the bit is cleared
 287:funsape/util/../globalDefines.hpp **** //!
 288:funsape/util/../globalDefines.hpp **** #   define isBitSet(reg, pos)           (bool_t)(((reg) >> (pos)) & 1)
 289:funsape/util/../globalDefines.hpp **** #endif
 290:funsape/util/../globalDefines.hpp **** 
 291:funsape/util/../globalDefines.hpp **** //     ///////////////////////     BIT LOOPING    ///////////////////////     //
 292:funsape/util/../globalDefines.hpp **** 
 293:funsape/util/../globalDefines.hpp **** #ifndef waitUntilBitIsClear
 294:funsape/util/../globalDefines.hpp **** //!
 295:funsape/util/../globalDefines.hpp **** //! @def            waitUntilBitIsClear(reg, pos)
 296:funsape/util/../globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 297:funsape/util/../globalDefines.hpp **** //!                     in register or variable @a reg is set.
 298:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 299:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
 300:funsape/util/../globalDefines.hpp **** //!
 301:funsape/util/../globalDefines.hpp **** #   define waitUntilBitIsClear(reg, pos)        do{     \
 302:funsape/util/../globalDefines.hpp ****         doNothing();                                    \
 303:funsape/util/../globalDefines.hpp ****     }while(isBitSet((reg), (pos)))
 304:funsape/util/../globalDefines.hpp **** #endif
 305:funsape/util/../globalDefines.hpp **** 
 306:funsape/util/../globalDefines.hpp **** #ifndef waitUntilBitIsSet
 307:funsape/util/../globalDefines.hpp **** //!
 308:funsape/util/../globalDefines.hpp **** //! @def            waitUntilBitIsSet(reg, pos)
 309:funsape/util/../globalDefines.hpp **** //! @details        Blocks the code execution while the bit in position @a pos
 310:funsape/util/../globalDefines.hpp **** //!                     in register or variable @a reg is cleared.
 311:funsape/util/../globalDefines.hpp **** //! @param[in]      reg                 register or variable
 312:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be evaluated
GAS LISTING /tmp/ccmJEIqf.s 			page 18


 313:funsape/util/../globalDefines.hpp **** //!
 314:funsape/util/../globalDefines.hpp **** #   define waitUntilBitIsSet(reg, pos)  do{     \
 315:funsape/util/../globalDefines.hpp ****         doNothing();                            \
 316:funsape/util/../globalDefines.hpp ****     } while (isBitClr((reg), (pos)))
 317:funsape/util/../globalDefines.hpp **** #endif
