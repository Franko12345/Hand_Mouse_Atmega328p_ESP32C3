 849:funsape/util/../globalDefines.hpp **** //! @param[in]      var1                first value
 850:funsape/util/../globalDefines.hpp **** //! @param[in]      var2                second value
 851:funsape/util/../globalDefines.hpp **** //! @return         the greater value between @a var1 and @a var2
 852:funsape/util/../globalDefines.hpp **** //!
 853:funsape/util/../globalDefines.hpp **** #define getMaximumOf(var1, var2)        (       \
 854:funsape/util/../globalDefines.hpp ****         ((var1) > (var2))                       \
 855:funsape/util/../globalDefines.hpp ****         ? (var1)                                \
 856:funsape/util/../globalDefines.hpp ****         : (var2)                                \
 857:funsape/util/../globalDefines.hpp **** )
 858:funsape/util/../globalDefines.hpp **** 
