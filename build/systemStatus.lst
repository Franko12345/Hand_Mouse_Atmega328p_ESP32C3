 384:funsape/util/../globalDefines.hpp **** //!
 385:funsape/util/../globalDefines.hpp **** //! @def            clrMaskOffset(reg, mask, offset)
 386:funsape/util/../globalDefines.hpp **** //! @details        Clears the bits of the register or variable @a reg that are
 387:funsape/util/../globalDefines.hpp **** //!                     set on the supplied mask @a mask. The mask is first
 388:funsape/util/../globalDefines.hpp **** //!                     left-shifted by the value given in @a offset.
 389:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
