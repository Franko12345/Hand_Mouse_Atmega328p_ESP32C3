 169:funsape/util/../globalDefines.hpp ****         (IS_GPIO_ALL_INSTANCE(gpioPort))                \
 170:funsape/util/../globalDefines.hpp ****         ? true                                          \
 171:funsape/util/../globalDefines.hpp ****         : false                                         \
 172:funsape/util/../globalDefines.hpp **** )
