 138:funsape/util/systemStatus.cpp **** bool_t SystemStatus::setClockPrescaler(ClockPrescaler prescaler_p)
 139:funsape/util/systemStatus.cpp **** {
 140:funsape/util/systemStatus.cpp ****     // Local variables
 141:funsape/util/systemStatus.cpp ****     uint8_t aux8 = 0;
 142:funsape/util/systemStatus.cpp ****     uint16_t aux16 = 0;
 143:funsape/util/systemStatus.cpp **** 
 144:funsape/util/systemStatus.cpp ****     // Decodes prescaler
 145:funsape/util/systemStatus.cpp ****     switch(prescaler_p) {
 146:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_1:
 147:funsape/util/systemStatus.cpp ****         aux8 = 0;
 148:funsape/util/systemStatus.cpp ****         aux16 = 1;
 149:funsape/util/systemStatus.cpp ****         break;
 150:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_2:
 151:funsape/util/systemStatus.cpp ****         aux8 = 1;
 152:funsape/util/systemStatus.cpp ****         aux16 = 2;
 153:funsape/util/systemStatus.cpp ****         break;
 154:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_4:
 155:funsape/util/systemStatus.cpp ****         aux8 = 2;
 156:funsape/util/systemStatus.cpp ****         aux16 = 4;
 157:funsape/util/systemStatus.cpp ****         break;
 158:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_8:
 159:funsape/util/systemStatus.cpp ****         aux8 = 3;
 160:funsape/util/systemStatus.cpp ****         aux16 = 8;
 161:funsape/util/systemStatus.cpp ****         break;
 162:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_32:
 163:funsape/util/systemStatus.cpp ****         aux8 = 4;
 164:funsape/util/systemStatus.cpp ****         aux16 = 32;
 165:funsape/util/systemStatus.cpp ****         break;
 166:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_64:
 167:funsape/util/systemStatus.cpp ****         aux8 = 5;
 168:funsape/util/systemStatus.cpp ****         aux16 = 64;
GAS LISTING /tmp/ccmJEIqf.s 			page 6


 169:funsape/util/systemStatus.cpp ****         break;
 170:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_128:
 171:funsape/util/systemStatus.cpp ****         aux8 = 6;
 172:funsape/util/systemStatus.cpp ****         aux16 = 128;
 173:funsape/util/systemStatus.cpp ****         break;
 174:funsape/util/systemStatus.cpp ****     case ClockPrescaler::PRESCALER_256:
 175:funsape/util/systemStatus.cpp ****         aux8 = 7;
 176:funsape/util/systemStatus.cpp ****         aux16 = 256;
 177:funsape/util/systemStatus.cpp ****         break;
