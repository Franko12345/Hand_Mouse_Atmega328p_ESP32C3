 106:funsape/util/systemStatus.cpp **** uint32_t SystemStatus::getElapsedTime(bool_t setNewMark_p)
 107:funsape/util/systemStatus.cpp **** {
 108:funsape/util/systemStatus.cpp ****     // Local variables
 109:funsape/util/systemStatus.cpp ****     uint32_t start = this->_stopwatchMark;
 110:funsape/util/systemStatus.cpp ****     uint32_t current = this->_stopwatchValue;
 111:funsape/util/systemStatus.cpp ****     uint32_t elapsed = 0;
GAS LISTING /tmp/ccmJEIqf.s 			page 5


 112:funsape/util/systemStatus.cpp **** 
 113:funsape/util/systemStatus.cpp ****     // Checks for errors
 114:funsape/util/systemStatus.cpp ****     if(!this->_initialized) {
 115:funsape/util/systemStatus.cpp ****         // Returns error
 116:funsape/util/systemStatus.cpp ****         this->_lastError                = Error::NOT_INITIALIZED;
 117:funsape/util/systemStatus.cpp ****         return false;
 118:funsape/util/systemStatus.cpp ****     }
 119:funsape/util/systemStatus.cpp **** 
 120:funsape/util/systemStatus.cpp ****     // Evaluate time elapsed between marks
 121:funsape/util/systemStatus.cpp ****     elapsed = (current > start) ? (current - start) : (((0xFFFFFFFF - start)  + current) + 1);
 122:funsape/util/systemStatus.cpp **** 
 123:funsape/util/systemStatus.cpp ****     // Sets new stopwatch mark
 124:funsape/util/systemStatus.cpp ****     if(setNewMark_p) {
 125:funsape/util/systemStatus.cpp ****         this->_stopwatchMark            = current;
 126:funsape/util/systemStatus.cpp ****     }
 127:funsape/util/systemStatus.cpp **** 
 128:funsape/util/systemStatus.cpp ****     // Returns value
 129:funsape/util/systemStatus.cpp ****     return elapsed;
 130:funsape/util/systemStatus.cpp **** }
