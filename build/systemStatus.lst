 362:funsape/util/../globalDefines.hpp **** //!
 363:funsape/util/../globalDefines.hpp **** #   define cplMask(reg, mask)           do{     \
 364:funsape/util/../globalDefines.hpp ****         (reg) ^= (mask);                        \
 365:funsape/util/../globalDefines.hpp ****     }while(0)
 366:funsape/util/../globalDefines.hpp **** #endif
 367:funsape/util/../globalDefines.hpp **** 
