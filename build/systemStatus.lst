 181:funsape/util/systemStatus.cpp ****     }
 182:funsape/util/systemStatus.cpp **** 
 183:funsape/util/systemStatus.cpp ****     // Changes system clock prescaler
 184:funsape/util/systemStatus.cpp ****     ATOMIC_BLOCK(ATOMIC_RESTORESTATE) {
 185:funsape/util/systemStatus.cpp ****         CLKPR = 0b10000000;
 186:funsape/util/systemStatus.cpp ****         CLKPR = aux8;
 187:funsape/util/systemStatus.cpp ****     }
 188:funsape/util/systemStatus.cpp **** 
 189:funsape/util/systemStatus.cpp ****     // Verifies if the change was successful
