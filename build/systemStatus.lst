 220:funsape/util/../globalDefines.hpp **** //!
 221:funsape/util/../globalDefines.hpp **** 
 222:funsape/util/../globalDefines.hpp **** //     //////////////////////     BIT HANDLING     //////////////////////     //
 223:funsape/util/../globalDefines.hpp **** 
 224:funsape/util/../globalDefines.hpp **** #ifndef clrBit
 225:funsape/util/../globalDefines.hpp **** //!
 226:funsape/util/../globalDefines.hpp **** //! @def            clrBit(reg, pos)
 227:funsape/util/../globalDefines.hpp **** //! @details        Clears the bit at position @a pos of the register or
 228:funsape/util/../globalDefines.hpp **** //!                     variable @a reg.
 229:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 230:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be cleared
 231:funsape/util/../globalDefines.hpp **** //!
 232:funsape/util/../globalDefines.hpp **** #   define clrBit(reg, pos)             do{     \
 233:funsape/util/../globalDefines.hpp ****         (reg) &= ~(1 << (pos));                 \
 234:funsape/util/../globalDefines.hpp ****     }while(0)
 235:funsape/util/../globalDefines.hpp **** #endif
 236:funsape/util/../globalDefines.hpp **** 
 237:funsape/util/../globalDefines.hpp **** #ifndef cplBit
 238:funsape/util/../globalDefines.hpp **** //!
 239:funsape/util/../globalDefines.hpp **** //! @def            cplBit(reg, pos)
 240:funsape/util/../globalDefines.hpp **** //! @details        Complements (invert) the bit at position @a pos of the
 241:funsape/util/../globalDefines.hpp **** //!                     register or variable @a reg.
 242:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
 243:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be complemented
 244:funsape/util/../globalDefines.hpp **** //!
 245:funsape/util/../globalDefines.hpp **** #   define cplBit(reg, pos)             do{     \
 246:funsape/util/../globalDefines.hpp ****         (reg) ^= (1 << (pos));                  \
 247:funsape/util/../globalDefines.hpp ****     }while(0)
 248:funsape/util/../globalDefines.hpp **** #endif
 249:funsape/util/../globalDefines.hpp **** 
 250:funsape/util/../globalDefines.hpp **** #ifndef setBit
 251:funsape/util/../globalDefines.hpp **** //!
 252:funsape/util/../globalDefines.hpp **** //! @def            setBit(reg, pos)
 253:funsape/util/../globalDefines.hpp **** //! @details        Sets the bit at position @a pos of the register or variable
 254:funsape/util/../globalDefines.hpp **** //!                     @a reg.
 255:funsape/util/../globalDefines.hpp **** //! @param[in,out]  reg                 register or variable
GAS LISTING /tmp/ccmJEIqf.s 			page 17


 256:funsape/util/../globalDefines.hpp **** //! @param[in]      pos                 position of the bit to be set
