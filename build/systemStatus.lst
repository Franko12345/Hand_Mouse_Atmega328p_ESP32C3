1288:funsape/util/../globalDefines.hpp **** //!
1289:funsape/util/../globalDefines.hpp **** enum class Axis : cuint8_t {
1290:funsape/util/../globalDefines.hpp ****     //                 Z-AXIS     Y-AXIS     X-AXIS
1291:funsape/util/../globalDefines.hpp ****     NONE            = (0 << 2) | (0 << 1) | (0 << 0),   //!< No axis selected
1292:funsape/util/../globalDefines.hpp ****     X               = (0 << 2) | (0 << 1) | (1 << 0),   //!< X axis selected
1293:funsape/util/../globalDefines.hpp ****     Y               = (0 << 2) | (1 << 1) | (0 << 0),   //!< Y axis selected
1294:funsape/util/../globalDefines.hpp ****     XY              = (0 << 2) | (1 << 1) | (1 << 0),   //!< X and Y axes selected
1295:funsape/util/../globalDefines.hpp ****     Z               = (1 << 2) | (0 << 1) | (0 << 0),   //!< Z axis selected
1296:funsape/util/../globalDefines.hpp ****     XZ              = (1 << 2) | (0 << 1) | (1 << 0),   //!< X and Z axes selected
1297:funsape/util/../globalDefines.hpp ****     YZ              = (1 << 2) | (1 << 1) | (0 << 0),   //!< Y and Z axes selected
1298:funsape/util/../globalDefines.hpp ****     ALL             = (1 << 2) | (1 << 1) | (1 << 0)    //!< X, Y and Z axes selected
1299:funsape/util/../globalDefines.hpp **** };
