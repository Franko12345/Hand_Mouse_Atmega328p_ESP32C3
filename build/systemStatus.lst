 195:funsape/util/systemStatus.cpp **** 
 196:funsape/util/systemStatus.cpp ****     // Update member data
 197:funsape/util/systemStatus.cpp ****     this->_clockPrescaler               = prescaler_p;
 198:funsape/util/systemStatus.cpp ****     this->_cpuClockValue                = this->_sourceClockValue / aux16;
 199:funsape/util/systemStatus.cpp **** 
