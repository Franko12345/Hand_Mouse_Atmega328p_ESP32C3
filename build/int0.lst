 149:funsape/peripheral/int0.cpp **** {
 150:funsape/peripheral/int0.cpp ****     // Mark passage for debugging purpose
 151:funsape/peripheral/int0.cpp ****     debugMark(PSTR("Int0::setPinMode(const PinMode)"), Debug::CodeIndex::INT0_MODULE);
 152:funsape/peripheral/int0.cpp **** 
 153:funsape/peripheral/int0.cpp ****     // Configure pin
 154:funsape/peripheral/int0.cpp ****     switch(mode_p) {
 155:funsape/peripheral/int0.cpp ****     case PinMode::INPUT_FLOATING:
 156:funsape/peripheral/int0.cpp ****         clrBit(MCU_INT0_GPIO_REG_DIR, MCU_INT0_GPIO_BIT_OFFSET);
 157:funsape/peripheral/int0.cpp ****         clrBit(MCU_INT0_GPIO_REG_OUT, MCU_INT0_GPIO_BIT_OFFSET);
 158:funsape/peripheral/int0.cpp ****         break;
 159:funsape/peripheral/int0.cpp ****     case PinMode::INPUT_PULLED_UP:
 160:funsape/peripheral/int0.cpp ****         clrBit(MCU_INT0_GPIO_REG_DIR, MCU_INT0_GPIO_BIT_OFFSET);
 161:funsape/peripheral/int0.cpp ****         setBit(MCU_INT0_GPIO_REG_OUT, MCU_INT0_GPIO_BIT_OFFSET);
 162:funsape/peripheral/int0.cpp ****         break;
 163:funsape/peripheral/int0.cpp ****     case PinMode::OUTPUT_PUSH_PULL:
 164:funsape/peripheral/int0.cpp ****         setBit(MCU_INT0_GPIO_REG_DIR, MCU_INT0_GPIO_BIT_OFFSET);
 165:funsape/peripheral/int0.cpp ****         break;
 166:funsape/peripheral/int0.cpp ****     }
 167:funsape/peripheral/int0.cpp **** 
 168:funsape/peripheral/int0.cpp ****     // Returns successfully
 169:funsape/peripheral/int0.cpp ****     this->_lastError = Error::NONE;
 170:funsape/peripheral/int0.cpp ****     debugMessage(Error::NONE, Debug::CodeIndex::INT0_MODULE);
 171:funsape/peripheral/int0.cpp ****     return true;
 172:funsape/peripheral/int0.cpp **** }
